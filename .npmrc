# Lock to npm registry — blocks dependency confusion redirects
registry=https://registry.npmjs.org/

# Prevent lifecycle scripts from running on install (postinstall, preinstall, etc.)
# This is the single highest-ROI line against supply chain attacks.
# event-stream (2018), ua-parser-js (2021), and color.js (2022) all exploited install scripts.
ignore-scripts=true

# Require package-lock.json to be present; fail if missing
package-lock=true

# Audit on install
audit=true

# Pin exact versions on npm install — no ^ ranges
save-exact=true
