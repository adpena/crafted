{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4321/action/fund-public-schools",
        "http://localhost:4321/action/protect-voting-rights",
        "http://localhost:4321/action/climate-action-now",
        "http://localhost:4321/action/healthcare-for-all",
        "http://localhost:4321/action/housing-justice",
        "http://localhost:4321/action/criminal-justice-reform"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
