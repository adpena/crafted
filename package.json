{
	"name": "crafted",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"emdash": {
		"seed": "seed/seed.json"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"deploy": "wrangler deploy",
		"typecheck": "astro check",
		"bootstrap": "emdash init && emdash seed",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:chromium": "playwright test --project=chromium",
		"test:e2e:firefox": "playwright test --project=firefox",
		"test:e2e:webkit": "playwright test --project=webkit",
		"test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
		"test:e2e:all": "playwright test",
		"lighthouse": "tsx scripts/lighthouse-audit.ts",
		"lint": "astro check",
		"verify": "npx tsx scripts/verify-disclaimers.ts",
		"refresh-homepage": "node --experimental-strip-types scripts/refresh-homepage.ts",
		"ship": "npm run refresh-homepage && npm run build && wrangler deploy"
	},
	"dependencies": {
		"@adpena/notifications": "0.1.0",
		"@astrojs/cloudflare": "^13.1.7",
		"@astrojs/react": "^5.0.3",
		"@emdash-cms/cloudflare": "0.1.0",
		"astro": "^6.1.4",
		"emdash": "0.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.8",
		"@axe-core/playwright": "4.11.1",
		"@cloudflare/workers-types": "^4.20260405.1",
		"@playwright/test": "^1.50.0",
		"tsx": "4.21.0",
		"vitest": "^4.1.3",
		"wrangler": "^4.80.0"
	}
}
