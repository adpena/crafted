{
	"name": "crafted",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"emdash": {
		"seed": "seed/seed.json"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"deploy": "wrangler deploy",
		"typecheck": "astro check",
		"bootstrap": "emdash init && emdash seed",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"lint": "astro check",
		"verify": "npx tsx scripts/verify-disclaimers.ts",
		"refresh-homepage": "node --experimental-strip-types scripts/refresh-homepage.ts",
		"ship": "npm run refresh-homepage && npm run build && wrangler deploy"
	},
	"dependencies": {
		"@astrojs/cloudflare": "13.1.3",
		"@emdash-cms/cloudflare": "0.1.0",
		"astro": "6.0.8",
		"emdash": "0.1.0"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.8",
		"@cloudflare/workers-types": "4.20260317.1",
		"@playwright/test": "^1.50.0",
		"vitest": "4.1.1",
		"wrangler": "4.77.0"
	}
}
