{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Disclaimer",
  "schema_version": "0.2.0",
  "type": "object",
  "required": [
    "jurisdiction",
    "type",
    "context",
    "required_text",
    "adapted_text",
    "statute_citation",
    "ai_disclosure_required",
    "ai_disclosure_text",
    "ai_disclosure_statute",
    "ai_disclosure_scope",
    "effective_date",
    "last_verified",
    "source_url"
  ],
  "properties": {
    "jurisdiction": {
      "type": "string",
      "description": "FED for federal, or 2-letter state code",
      "pattern": "^(FED|[A-Z]{2})$"
    },
    "type": {
      "type": "string",
      "enum": ["digital", "print", "broadcast", "sms", "email"]
    },
    "context": {
      "type": "string",
      "enum": ["general", "candidate_authorized", "independent_expenditure", "pac"],
      "description": "Disambiguates when a jurisdiction has different rules for different entity types"
    },
    "required_text": {
      "type": "string",
      "description": "Template with placeholders: {committee_name}, {treasurer_name}, {address}, {candidate_name}, {office}, {party_affiliation}, {media_type}"
    },
    "adapted_text": {
      "type": ["string", "null"]
    },
    "statute_citation": {
      "type": "string"
    },
    "ai_disclosure_required": {
      "type": "boolean"
    },
    "ai_disclosure_text": {
      "type": ["string", "null"]
    },
    "ai_disclosure_statute": {
      "type": ["string", "null"],
      "description": "Separate citation for the AI disclosure statute when it differs from the main disclaimer statute"
    },
    "ai_disclosure_scope": {
      "type": ["string", "null"],
      "description": "Free text describing conditional triggers for the AI disclosure requirement"
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "last_verified": {
      "type": "string",
      "format": "date"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    }
  },
  "additionalProperties": false
}
