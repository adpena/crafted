---
const { slug } = Astro.params;
if (!slug || !/^[a-z0-9][a-z0-9-]*$/.test(slug)) {
  return new Response("Not found", { status: 404 });
}

const isEmbed = Astro.url.searchParams.get("embed") === "1";

import { env } from "cloudflare:workers";
const db = env.DB;

let pageData: Record<string, any> | null = null;
try {
  const row = await db.prepare(
    "SELECT data FROM _plugin_storage WHERE plugin_id = 'action-pages' AND collection = 'action_pages' AND json_extract(data, '$.slug') = ?"
  ).bind(slug).first();
  if (row?.data) {
    pageData = typeof row.data === "string" ? JSON.parse(row.data) : row.data;
  }
} catch (e) {
  console.error("Action page query failed:", e);
}

if (!pageData) {
  return new Response("Action page not found", { status: 404 });
}

// Validate ActBlue URL
let actblueUrl = "";
try {
  const raw = pageData.actblue_url ?? pageData.action_props?.actblue_url ?? "";
  if (raw) {
    const parsed = new URL(raw);
    if (parsed.protocol === "https:" && (parsed.hostname === "secure.actblue.com" || parsed.hostname === "actblue.com")) {
      actblueUrl = parsed.href;
    }
  }
} catch {}

const actionType = pageData.action ?? pageData.type ?? "fundraise";
const actionConfig = {
  slug,
  template: pageData.template ?? "hero-simple",
  template_props: pageData.template_props ?? {
    headline: pageData.title ?? "Action Page",
    subhead: pageData.body ?? "",
  },
  action: actionType,
  action_props: pageData.action_props ?? {
    amounts: pageData.amount_config?.base ?? [10, 25, 50, 100, 250],
    actblue_url: actblueUrl,
    refcode: pageData.refcode ?? "",
  },
  followup: pageData.followup ?? undefined,
  followup_props: pageData.followup_props ?? undefined,
  followup_message: pageData.followup_message ?? undefined,
  disclaimer: pageData.disclaimer ?? {
    committee_name: pageData.committee_name ?? "",
  },
  locale: pageData.locale ?? "en",
  consent: pageData.consent ?? undefined,
  theme: pageData.theme ?? "warm",
  callbacks: pageData.callbacks ?? [],
};

const title = pageData.template_props?.headline ?? pageData.title ?? "Action Page";
const ogDescription = (
  pageData.template_props?.subhead ??
  (pageData.template_props?.body ?? "").slice(0, 160) ??
  ""
).replace(/<[^>]*>/g, "").trim();
const canonicalUrl = `https://adpena.com/action/${slug}`;
const ogImage =
  pageData.template_props?.media_url ??
  pageData.template_props?.background_image ??
  pageData.template_props?.image_url ??
  "https://adpena.com/og-default.png";

// Resolve theme server-side — each page gets its own visual identity
const THEMES: Record<string, Record<string, string>> = {
  warm: { "--page-bg":"#f5f5f0","--page-text":"#1a1a1a","--page-accent":"#1a1a1a","--page-secondary":"#6b6b6b","--page-border":"#d4d4c8","--page-radius":"0px","--page-font-serif":"Georgia, 'Times New Roman', serif","--page-font-mono":"'SF Mono', 'Fira Code', monospace" },
  bold: { "--page-bg":"#0a0a0a","--page-text":"#ffffff","--page-accent":"#ef4444","--page-secondary":"#a1a1a1","--page-border":"#2a2a2a","--page-radius":"8px","--page-font-serif":"Inter, system-ui, sans-serif","--page-font-mono":"'SF Mono', 'Fira Code', monospace" },
  clean: { "--page-bg":"#ffffff","--page-text":"#1a1a1a","--page-accent":"#2563eb","--page-secondary":"#6b7280","--page-border":"#e5e5e5","--page-radius":"4px","--page-font-serif":"system-ui, -apple-system, sans-serif","--page-font-mono":"'SF Mono', 'Fira Code', monospace" },
};

// Support custom theme objects from the page config
const resolvedTheme = typeof actionConfig.theme === "object"
  ? actionConfig.theme
  : THEMES[actionConfig.theme as string] ?? THEMES.warm;

const cssVarString = Object.entries(resolvedTheme).map(([k, v]) => `${k}:${v}`).join(";");

import ActionPageIsland from "../../components/ActionPageIsland.tsx";
---

<html lang={actionConfig.locale === "es" ? "es" : "en"}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={ogDescription} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--page-font-serif);
      line-height: 1.6;
      color: var(--page-text);
      background: var(--page-bg);
      min-height: 100vh;
    }

    /* Hero templates render full-width; action forms are centered */
    main { width: 100%; }
    astro-island { display: contents; }
  </style>
</head>
<body style={cssVarString}>
  <main id="main-content">
    <ActionPageIsland page={actionConfig} client:load />
  </main>

  {isEmbed && (
    <script>
      (function() {
        if (window === window.parent) return;
        var MSG = "crafted:resize";
        var last = 0;
        var timer = null;
        function report() {
          var h = document.documentElement.scrollHeight;
          if (h !== last) {
            last = h;
            var target = "*";
            try { if (document.referrer) target = new URL(document.referrer).origin; } catch (e) {}
            window.parent.postMessage({ type: MSG, height: h }, target);
          }
        }
        function debounced() { clearTimeout(timer); timer = setTimeout(report, 100); }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", report);
        } else { report(); }
        var obs = new MutationObserver(debounced);
        obs.observe(document.body, { childList: true, subtree: true, attributes: true, characterData: true });
        window.addEventListener("load", report);
        window.addEventListener("resize", debounced);
      })();
    </script>
  )}
</body>
</html>
