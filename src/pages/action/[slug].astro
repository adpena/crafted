---
const { slug } = Astro.params;
if (!slug || !/^[a-z0-9][a-z0-9-]*$/.test(slug)) {
  return new Response("Not found", { status: 404 });
}

const embedParam = Astro.url.searchParams.get("embed");
const embedMode = embedParam === "1" ? "embed"
  : embedParam === "stacked" ? "stacked"
  : "standalone" as const;
const isEmbed = embedMode !== "standalone";

// Access the plugin storage directly via D1
import { env } from "cloudflare:workers";
const db = env.DB;

let pageData: Record<string, any> | null = null;
try {
  const row = await db.prepare(
    "SELECT data FROM _plugin_storage WHERE plugin_id = 'crafted-action-pages' AND collection = 'action_pages' AND json_extract(data, '$.slug') = ?"
  ).bind(slug).first();
  if (row?.data) {
    pageData = typeof row.data === "string" ? JSON.parse(row.data) : row.data;
  }
} catch (e) {
  console.error("Action page query failed:", e);
}

if (!pageData) {
  return new Response("Action page not found", { status: 404 });
}

// Validate ActBlue URL
let actblueUrl = "";
try {
  const raw = pageData.actblue_url ?? "";
  if (raw) {
    const parsed = new URL(raw);
    if (parsed.protocol === "https:" && (parsed.hostname === "secure.actblue.com" || parsed.hostname === "actblue.com")) {
      actblueUrl = parsed.href;
    }
  }
} catch { /* invalid URL, leave empty */ }

// Map D1 row data -> ActionPageConfig for the renderer.
// Pages stored before the renderer existed have flat fields (title, body,
// actblue_url, etc.). Pages created with the new MCP/admin tools store
// nested template_props / action_props with `action` (not `type`). Handle
// both shapes — prefer the new shape's `action` field, fall back to legacy
// `type`, and finally default to "fundraise" so legacy demo rows render.
const actionType = pageData.action ?? pageData.type ?? "fundraise";
const actionConfig = {
  slug,
  template: pageData.template ?? "hero-simple",
  template_props: pageData.template_props ?? {
    headline: pageData.title ?? "Action Page",
    subhead: pageData.body ?? "",
  },
  action: actionType,
  action_props: pageData.action_props ?? {
    amounts: pageData.amount_config?.base ?? [10, 25, 50, 100, 250],
    actblue_url: actblueUrl,
    refcode: pageData.refcode ?? "",
  },
  followup: pageData.followup ?? undefined,
  followup_props: pageData.followup_props ?? undefined,
  followup_message: pageData.followup_message ?? undefined,
  disclaimer: pageData.disclaimer ?? {
    committee_name: pageData.committee_name ?? "",
  },
  theme: pageData.theme ?? "warm",
  callbacks: pageData.callbacks ?? [],
};

const title = pageData.template_props?.headline ?? pageData.title ?? "Action Page";

import ActionPageIsland from "../../components/ActionPageIsland.tsx";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <!-- Self-contained styles: action pages are embeddable widgets (iframe)
       that render outside the main site layout. Hex values intentionally
       duplicate the design tokens for zero-dependency embedding. -->
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --page-bg: #f5f5f0;
      --page-text: #1a1a1a;
      --page-accent: #1a1a1a;
      --page-secondary: #6b6b6b;
      --page-border: #d4d4c8;
      --page-radius: 0px;
      --page-font-serif: Georgia, 'Times New Roman', serif;
      --page-font-mono: 'SF Mono', 'Fira Code', monospace;
    }

    body {
      font-family: var(--page-font-serif);
      line-height: 1.6;
      color: var(--page-text);
      background: var(--page-bg);
      padding: 3rem 1.5rem;
      max-width: 32rem;
      margin: 0 auto;
    }

    astro-island { display: contents; }

    @media (max-width: 480px) {
      body { padding: 1.5rem 1rem; max-width: 100%; }
    }
  </style>
</head>
<body>
  <main id="main-content">
    <ActionPageIsland page={actionConfig} client:load />
  </main>

  {isEmbed && (
    <script>
      // Embed resize: report content height to parent frame via postMessage.
      // Inlined to avoid an extra network request for the embed case.
      (function() {
        if (window === window.parent) return;
        var MSG = "crafted:resize";
        var last = 0;
        var timer = null;
        function report() {
          var h = document.documentElement.scrollHeight;
          if (h !== last) {
            last = h;
            // Restrict targetOrigin to the embedding parent's origin to avoid
            // broadcasting to any frame. Falls back to "*" only if the embedder
            // is unknown (no referrer), preserving compatibility.
            var target = "*";
            try { if (document.referrer) target = new URL(document.referrer).origin; } catch (e) {}
            window.parent.postMessage({ type: MSG, height: h }, target);
          }
        }
        function debounced() { clearTimeout(timer); timer = setTimeout(report, 100); }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", report);
        } else { report(); }
        var obs = new MutationObserver(debounced);
        obs.observe(document.body, { childList: true, subtree: true, attributes: true, characterData: true });
        window.addEventListener("load", report);
        window.addEventListener("resize", debounced);
      })();
    </script>
  )}
</body>
</html>
