---
export const prerender = false;

import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";

const { entries: projects, cacheHint } = await getEmDashCollection("projects");

try { Astro.cache.set(cacheHint); } catch {}

const projectsWithTags = await Promise.all(
	projects.map(async (project) => {
		const tags = await getEntryTerms("projects", project.data.id, "tag");
		return { project, tags };
	})
);

// Section definitions — order matters
const sections = [
	{ label: "Development", match: ["typescript", "python", "rust", "django", "wordpress", "astro", "wasm", "cloudflare"] },
	{ label: "Design", match: ["design", "ui-ux", "identity", "art-direction"] },
	{ label: "Policy", match: ["policy", "compliance", "campaign-tech"] },
	{ label: "Writing", match: ["writing", "editorial"] },
];

type SectionedProject = { project: typeof projects[0]; tags: Awaited<ReturnType<typeof getEntryTerms>> };

const placed = new Set<string>();
const sectionedProjects: { label: string; items: SectionedProject[] }[] = [];

for (const section of sections) {
	const items = projectsWithTags.filter(({ project, tags }) => {
		if (placed.has(project.data.id)) return false;
		return tags.some((t) => section.match.includes(t.slug));
	});
	if (items.length > 0) {
		items.forEach(({ project }) => placed.add(project.data.id));
		sectionedProjects.push({ label: section.label, items });
	}
}

// Catch any unplaced projects
const unplaced = projectsWithTags.filter(({ project }) => !placed.has(project.data.id));
if (unplaced.length > 0) {
	sectionedProjects.push({ label: "Other", items: unplaced });
}
---

<Base title="Work">
	<main id="main-content" class="work-page">
		{sectionedProjects.length > 0 ? (
			sectionedProjects.map((section) => (
				<section class="work-section">
					<h2 class="section-heading">{section.label}</h2>
					<ul class="project-list" role="list">
						{section.items.map(({ project, tags }) => (
							<li>
								<a href={`/work/${project.id}`} class="project-link">
									<span class="project-name">{project.data.title}</span>
									{project.data.summary && (
										<span class="project-summary">{project.data.summary}</span>
									)}
								</a>
							</li>
						))}
					</ul>
				</section>
			))
		) : (
			<p class="empty">No projects yet.</p>
		)}
	</main>
</Base>

<style>
	.work-page {
		max-width: 42rem;
		margin: 0 auto;
		padding: var(--spacing-lg) 0 var(--spacing-2xl);
	}

	.work-section {
		margin-bottom: var(--spacing-xl);
	}

	.section-heading {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-secondary);
		padding-bottom: var(--spacing-sm);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--spacing-md);
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.project-link {
		display: block;
		padding: var(--spacing-sm) 0;
		text-decoration: none;
		color: inherit;
		transition: opacity 150ms ease;
	}

	.project-link:hover {
		opacity: 0.65;
	}

	.project-name {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: 600;
	}

	.project-summary {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		color: var(--color-secondary);
		line-height: 1.5;
		margin-top: 0.15rem;
	}

	.empty {
		color: var(--color-secondary);
		text-align: center;
		padding: var(--spacing-3xl) 0;
	}
</style>
