---
export const prerender = false;

import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";

const { entries: projects, cacheHint } = await getEmDashCollection("projects");

try { Astro.cache.set(cacheHint); } catch {}

const sorted = projects.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const projectsWithTags = await Promise.all(
	sorted.map(async (project) => {
		const tags = await getEntryTerms("projects", project.data.id, "tag");
		return { project, tags };
	})
);
---

<Base title="Work">
	<main id="main-content" class="work-page">
		{projectsWithTags.length > 0 ? (
			<ul class="project-list" role="list">
				{projectsWithTags.map(({ project, tags }) => (
					<li class="project-item">
						<a href={`/work/${project.id}`} class="project-link">
							<h2 class="project-name">{project.data.title}</h2>
							{project.data.summary && (
								<p class="project-summary">{project.data.summary}</p>
							)}
							{tags.length > 0 && (
								<span class="project-tags mono">
									{tags.map((t) => t.label).join(" · ")}
								</span>
							)}
						</a>
					</li>
				))}
			</ul>
		) : (
			<p class="empty">No projects yet.</p>
		)}
	</main>
</Base>

<style>
	.work-page {
		padding: var(--spacing-xl) 0 var(--spacing-3xl);
		max-width: 42rem;
		margin: 0 auto;
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.project-item {
		border-bottom: 1px solid var(--color-border);
	}

	.project-link {
		display: block;
		padding: var(--spacing-lg) 0;
		text-decoration: none;
		color: inherit;
		transition: opacity 150ms ease;
	}

	.project-link:hover {
		opacity: 0.7;
	}

	.project-name {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 600;
		margin: 0 0 var(--spacing-xs);
	}

	.project-summary {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		color: var(--color-secondary);
		line-height: 1.5;
		margin: 0 0 var(--spacing-sm);
	}

	.project-tags {
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
	}

	.empty {
		color: var(--color-secondary);
		text-align: center;
		padding: var(--spacing-3xl) 0;
	}
</style>
