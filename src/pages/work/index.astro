---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const collectionDefs = [
	{ slug: "dev", label: "Development" },
	{ slug: "design", label: "Design" },
	{ slug: "policy", label: "Policy" },
	{ slug: "writing", label: "Writing" },
];

type Entry = { id: string; data: Record<string, any> };
type Section = { label: string; slug: string; entries: Entry[] };

// Manual ordering overrides (slug → sort priority, lower = first)
const ORDER: Record<string, number> = {
	"molt": 1,
	"crafted-action-pages": 2,
	"reproq": 3,
};

// Parallel queries — all collections at once
const results = await Promise.all(
	collectionDefs.map(async (def) => {
		try {
			const result = await getEmDashCollection(def.slug);
			if (result.cacheHint) {
				try { Astro.cache.set(result.cacheHint); } catch {}
			}
			if (result.entries?.length > 0) {
				const sorted = [...result.entries].sort((a, b) => {
					const oa = ORDER[a.id] ?? 100;
					const ob = ORDER[b.id] ?? 100;
					if (oa !== ob) return oa - ob;
					const ya = parseInt(a.data.year ?? "0", 10);
					const yb = parseInt(b.data.year ?? "0", 10);
					return yb - ya;
				});
				return { ...def, entries: sorted };
			}
		} catch {}
		return null;
	})
);

const sections: Section[] = results.filter((s): s is Section => s !== null);

const highlights = [
	{ title: "Molt", desc: "Python-to-Wasm compiler", href: "/work/dev/molt", tag: "Featured" },
	{ title: "Lost Decade", desc: "Analysis → 11% raise for educators", href: "/work/policy/the-lost-decade-and-a-half", tag: "Impact" },
	{ title: "Action Pages", desc: "Live campaign page engine", href: "/action/demo-donate", tag: "Demo" },
	{ title: "Respect Campaign", desc: "District-level interactive map", href: "/work/design/respect-campaign-map", tag: "Featured" },
	{ title: "teadata", desc: "TX education data suite (3 repos)", href: "/work/dev/data-for-public-education", tag: "OSS" },
];
---

<Base title="Work">
	<main id="main-content" class="work-layout">
		<div class="work-main">
			{sections.map((section) => (
				<section class="work-section">
					<h2 class="section-label">{section.label}</h2>
					<ul class="compact-list" role="list">
						{section.entries.map((entry) => {
							const tags = entry.data.stack ?? entry.data.publication ?? entry.data.medium ?? "";
							return (
							<li>
								<a href={`/work/${section.slug}/${entry.id}`} class="compact-item">
									<span class="compact-title">{entry.data.title}</span>
									<span class="compact-tags">{tags}</span>
									<span class="compact-year">{entry.data.year ?? (entry.data.date ? new Date(entry.data.date).getFullYear() : "")}</span>
								</a>
								<div class="compact-reveal">
									<div>
										{entry.data.summary && <p>{entry.data.summary}</p>}
									</div>
								</div>
							</li>
							);
						})}
					</ul>
				</section>
			))}
		</div>

		<aside class="work-sidebar" aria-label="Highlighted projects">
			<h2 class="section-label">Highlights</h2>
			<nav class="highlights">
				{highlights.map((h) => (
					<a href={h.href} class="highlight">
						<span class="highlight-tag">{h.tag}</span>
						<span class="highlight-title">{h.title}</span>
						<span class="highlight-desc">{h.desc}</span>
					</a>
				))}
			</nav>
		</aside>
	</main>
</Base>

<style>
	.work-layout {
		max-width: 56rem;
		margin: 0 auto;
		padding: var(--spacing-lg) var(--content-padding) var(--spacing-2xl);
		display: grid;
		grid-template-columns: 1fr 14rem;
		gap: var(--spacing-2xl);
		align-items: start;
	}

	.work-section {
		margin-bottom: var(--spacing-2xl);
	}

	/* Compact list: title + year on one line, summary reveals on hover */
	.compact-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.compact-list li {
		border-bottom: 1px solid var(--color-border);
	}

	.compact-list li {
		border-left: 2px solid transparent;
		padding-left: var(--spacing-md);
		transition: border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.compact-list li:hover,
	.compact-list li:focus-within {
		border-left-color: var(--color-text);
	}

	.compact-item {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.45rem 0;
		text-decoration: none;
		color: inherit;
		gap: var(--spacing-md);
		transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.compact-item:hover {
		color: var(--color-text);
	}

	.compact-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
	}

	.compact-tags {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		flex: 1;
		text-align: right;
		opacity: 1;
		transition: opacity 200ms cubic-bezier(0.4, 0, 0.2, 1);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		max-width: 20rem;
	}

	.compact-list li:hover .compact-tags,
	.compact-list li:focus-within .compact-tags {
		opacity: 0;
	}

	.compact-year {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		flex-shrink: 0;
	}

	.compact-reveal {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 250ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.compact-list li:hover .compact-reveal,
	.compact-list li:focus-within .compact-reveal {
		grid-template-rows: 1fr;
		transition-delay: 80ms;
	}

	.compact-reveal > * {
		overflow: hidden;
	}

	.compact-reveal p {
		font-size: var(--font-size-sm);
		color: var(--color-secondary);
		line-height: 1.4;
		margin: 0;
		padding-bottom: 0.5rem;
	}

	.compact-meta {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-top: 0.15rem;
	}

	/* Sidebar */
	.work-sidebar {
		position: sticky;
		top: var(--spacing-lg);
	}

	.highlights {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
	}

	.highlight {
		display: block;
		padding: var(--spacing-sm) var(--spacing-md);
		text-decoration: none;
		color: inherit;
		border-left: 2px solid var(--color-border);
		transition: border-color 200ms cubic-bezier(0.4, 0, 0.2, 1), transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.highlight:hover {
		border-left-color: var(--color-text);
		transform: translateX(2px);
	}

	.highlight-tag {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-secondary);
		margin-bottom: 0.15rem;
	}

	.highlight-title {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		font-weight: 600;
	}

	.highlight-desc {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		line-height: 1.4;
	}

	@media (max-width: 768px) {
		.work-layout {
			grid-template-columns: 1fr;
		}

		.work-sidebar {
			position: static;
			order: -1;
			padding-bottom: var(--spacing-lg);
			border-bottom: 1px solid var(--color-border);
			margin-bottom: var(--spacing-lg);
		}

		.highlights {
			flex-direction: row;
			overflow-x: auto;
			gap: var(--spacing-md);
			padding-bottom: var(--spacing-sm);
			-webkit-overflow-scrolling: touch;
		}

		.highlight {
			min-width: 10rem;
			border-left: none;
			border-top: 2px solid var(--color-border);
			padding: var(--spacing-sm) var(--spacing-xs) 0;
			min-height: 44px;
		}

		.highlight:hover {
			border-top-color: var(--color-text);
			transform: none;
		}

		/* On mobile, always show summaries (no hover on touch) */
		.compact-reveal {
			grid-template-rows: 1fr;
		}

		.compact-list li {
			border-left-color: transparent;
		}

		/* Touch-friendly compact items */
		.compact-item {
			padding: var(--spacing-sm) 0;
			min-height: 44px;
		}

		.highlight-tag {
			font-size: var(--font-size-xs);
		}
	}

	@media (max-width: 480px) {
		.work-layout {
			padding-top: var(--spacing-md);
		}

		.highlights {
			gap: var(--spacing-sm);
		}

		.highlight {
			min-width: 8.5rem;
		}

		.compact-title {
			font-size: var(--font-size-base);
		}
	}
</style>
