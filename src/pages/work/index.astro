---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const collectionDefs = [
	{ slug: "dev_projects", label: "Development" },
	{ slug: "design_work", label: "Design" },
	{ slug: "policy_work", label: "Policy" },
	{ slug: "writing", label: "Writing" },
];

type Entry = { id: string; data: Record<string, any> };
type Section = { label: string; slug: string; entries: Entry[] };

const sections: Section[] = [];

for (const def of collectionDefs) {
	try {
		const result = await getEmDashCollection(def.slug);
		if (result.entries?.length > 0) {
			const sorted = [...result.entries].sort((a, b) => {
				const ya = parseInt(a.data.year ?? "0", 10);
				const yb = parseInt(b.data.year ?? "0", 10);
				return yb - ya;
			});
			sections.push({ ...def, entries: sorted });
		}
		if (result.cacheHint) {
			try { Astro.cache.set(result.cacheHint); } catch {}
		}
	} catch {}
}

// Highlighted projects — curated, not algorithmic
const highlights = [
	{ title: "Molt", desc: "Python-to-Wasm compiler", href: "/work/dev_projects/molt", tag: "New" },
	{ title: "Lost Decade", desc: "Salary analysis → 11% raise", href: "/work/policy_work/the-lost-decade-and-a-half", tag: "Impact" },
	{ title: "Action Pages", desc: "Campaign tech plugin", href: "/action/demo-donate", tag: "Demo" },
	{ title: "Respect Campaign", desc: "Interactive district map", href: "/work/design_work/respect-campaign-map", tag: "Visual" },
	{ title: "teadata", desc: "TX education data suite", href: "/work/dev_projects/texas-education-data-mcp-server", tag: "OSS" },
];
---

<Base title="Work">
	<main id="main-content" class="work-layout">
		<div class="work-main">
			{sections.length > 0 ? (
				sections.map((section) => (
					<section class="work-section">
						<h2 class="section-label">{section.label}</h2>
						<ul class="item-list" role="list">
							{section.entries.map((entry) => (
								<li>
									<a href={`/work/${section.slug}/${entry.id}`} class="item-link">
										<span class="item-title">{entry.data.title}</span>
										{entry.data.summary && <span class="item-desc">{entry.data.summary}</span>}
										{entry.data.stack && <span class="item-meta">{entry.data.stack}</span>}
										{entry.data.publication && <span class="item-meta">{entry.data.publication}</span>}
										{entry.data.medium && <span class="item-meta">{entry.data.medium}</span>}
									</a>
								</li>
							))}
						</ul>
					</section>
				))
			) : (
				<p class="empty">No work yet.</p>
			)}
		</div>

		<aside class="work-sidebar" aria-label="Highlighted projects">
			<h2 class="section-label">Highlights</h2>
			<nav class="highlights">
				{highlights.map((h) => (
					<a href={h.href} class="highlight">
						<span class="highlight-tag">{h.tag}</span>
						<span class="highlight-title">{h.title}</span>
						<span class="highlight-desc">{h.desc}</span>
					</a>
				))}
			</nav>
		</aside>
	</main>
</Base>

<style>
	.work-layout {
		max-width: 56rem;
		margin: 0 auto;
		padding: var(--spacing-lg) var(--content-padding) var(--spacing-2xl);
		display: grid;
		grid-template-columns: 1fr 14rem;
		gap: var(--spacing-2xl);
		align-items: start;
	}

	.work-section {
		margin-bottom: var(--spacing-xl);
	}

	.work-sidebar {
		position: sticky;
		top: var(--spacing-lg);
	}

	.highlights {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
	}

	.highlight {
		display: block;
		padding: var(--spacing-sm) var(--spacing-md);
		text-decoration: none;
		color: inherit;
		border-left: 2px solid var(--color-border);
		transition: border-color 150ms ease;
	}

	.highlight:hover {
		border-left-color: var(--color-text);
		opacity: 1;
	}

	.highlight-tag {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-secondary);
		margin-bottom: 0.15rem;
	}

	.highlight-title {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		font-weight: 600;
	}

	.highlight-desc {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		line-height: 1.4;
	}

	@media (max-width: 768px) {
		.work-layout {
			grid-template-columns: 1fr;
		}

		.work-sidebar {
			position: static;
			order: -1;
			padding-bottom: var(--spacing-lg);
			border-bottom: 1px solid var(--color-border);
			margin-bottom: var(--spacing-lg);
		}

		.highlights {
			flex-direction: row;
			overflow-x: auto;
			gap: var(--spacing-md);
			padding-bottom: var(--spacing-sm);
		}

		.highlight {
			min-width: 10rem;
			border-left: none;
			border-top: 2px solid var(--color-border);
			padding: var(--spacing-sm) 0 0;
		}

		.highlight:hover {
			border-top-color: var(--color-text);
		}
	}
</style>
