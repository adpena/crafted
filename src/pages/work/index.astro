---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const collectionDefs = [
	{ slug: "dev_projects", label: "Development" },
	{ slug: "design_work", label: "Design" },
	{ slug: "policy_work", label: "Policy" },
	{ slug: "writing", label: "Writing" },
];

type Entry = { id: string; data: Record<string, any> };
type Section = { label: string; slug: string; entries: Entry[] };

const sections: Section[] = [];

// Manual ordering overrides (slug → sort priority, lower = first)
const ORDER: Record<string, number> = {
	"molt": 1,
	"crafted-action-pages": 2,
	"reproq": 3,
};

for (const def of collectionDefs) {
	try {
		const result = await getEmDashCollection(def.slug);
		if (result.entries?.length > 0) {
			const sorted = [...result.entries].sort((a, b) => {
				const oa = ORDER[a.id] ?? 100;
				const ob = ORDER[b.id] ?? 100;
				if (oa !== ob) return oa - ob;
				const ya = parseInt(a.data.year ?? "0", 10);
				const yb = parseInt(b.data.year ?? "0", 10);
				return yb - ya;
			});
			sections.push({ ...def, entries: sorted });
		}
		if (result.cacheHint) {
			try { Astro.cache.set(result.cacheHint); } catch {}
		}
	} catch {}
}

const highlights = [
	{ title: "Molt", desc: "Python-to-Wasm compiler", href: "/work/dev_projects/molt", tag: "Featured" },
	{ title: "Lost Decade", desc: "Analysis → 11% raise for educators", href: "/work/policy_work/the-lost-decade-and-a-half", tag: "Impact" },
	{ title: "Action Pages", desc: "Live campaign page engine", href: "/action/demo-donate", tag: "Demo" },
	{ title: "Respect Campaign", desc: "District-level interactive map", href: "/work/design_work/respect-campaign-map", tag: "Featured" },
	{ title: "teadata", desc: "TX education data suite (3 repos)", href: "/work/dev_projects/texas-education-data-mcp-server", tag: "Tool" },
];
---

<Base title="Work">
	<main id="main-content" class="work-layout">
		<div class="work-main">
			{sections.map((section) => (
				<section class="work-section">
					<h2 class="section-label">{section.label}</h2>
					<ul class="compact-list" role="list">
						{section.entries.map((entry) => (
							<li>
								<a href={`/work/${section.slug}/${entry.id}`} class="compact-item">
									<span class="compact-title">{entry.data.title}</span>
									<span class="compact-year">{entry.data.year}</span>
								</a>
								<div class="compact-reveal">
									{entry.data.summary && <p>{entry.data.summary}</p>}
									{entry.data.stack && <span class="compact-meta">{entry.data.stack}</span>}
									{entry.data.publication && <span class="compact-meta">{entry.data.publication}</span>}
								</div>
							</li>
						))}
					</ul>
				</section>
			))}
		</div>

		<aside class="work-sidebar" aria-label="Highlighted projects">
			<h2 class="section-label">Highlights</h2>
			<nav class="highlights">
				{highlights.map((h) => (
					<a href={h.href} class="highlight">
						<span class="highlight-tag">{h.tag}</span>
						<span class="highlight-title">{h.title}</span>
						<span class="highlight-desc">{h.desc}</span>
					</a>
				))}
			</nav>
		</aside>
	</main>
</Base>

<style>
	.work-layout {
		max-width: 56rem;
		margin: 0 auto;
		padding: var(--spacing-lg) var(--content-padding) var(--spacing-2xl);
		display: grid;
		grid-template-columns: 1fr 14rem;
		gap: var(--spacing-2xl);
		align-items: start;
	}

	.work-section {
		margin-bottom: var(--spacing-lg);
	}

	/* Compact list: title + year on one line, summary reveals on hover */
	.compact-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.compact-list li {
		border-bottom: 1px solid var(--color-border);
	}

	.compact-item {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.45rem 0;
		text-decoration: none;
		color: inherit;
		gap: var(--spacing-md);
	}

	.compact-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
	}

	.compact-year {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		flex-shrink: 0;
	}

	.compact-reveal {
		max-height: 0;
		overflow: hidden;
		transition: max-height 200ms ease, padding 200ms ease;
		padding: 0;
	}

	.compact-list li:hover .compact-reveal,
	.compact-list li:focus-within .compact-reveal {
		max-height: 6rem;
		padding: 0 0 0.5rem;
	}

	.compact-reveal p {
		font-size: var(--font-size-sm);
		color: var(--color-secondary);
		line-height: 1.4;
		margin: 0;
	}

	.compact-meta {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-top: 0.15rem;
	}

	/* Sidebar */
	.work-sidebar {
		position: sticky;
		top: var(--spacing-lg);
	}

	.highlights {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
	}

	.highlight {
		display: block;
		padding: var(--spacing-sm) var(--spacing-md);
		text-decoration: none;
		color: inherit;
		border-left: 2px solid var(--color-border);
		transition: border-color 150ms ease;
	}

	.highlight:hover {
		border-left-color: var(--color-text);
		opacity: 1;
	}

	.highlight-tag {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-secondary);
		margin-bottom: 0.15rem;
	}

	.highlight-title {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		font-weight: 600;
	}

	.highlight-desc {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		line-height: 1.4;
	}

	@media (max-width: 768px) {
		.work-layout {
			grid-template-columns: 1fr;
		}

		.work-sidebar {
			position: static;
			order: -1;
			padding-bottom: var(--spacing-lg);
			border-bottom: 1px solid var(--color-border);
			margin-bottom: var(--spacing-lg);
		}

		.highlights {
			flex-direction: row;
			overflow-x: auto;
			gap: var(--spacing-md);
			padding-bottom: var(--spacing-sm);
		}

		.highlight {
			min-width: 10rem;
			border-left: none;
			border-top: 2px solid var(--color-border);
			padding: var(--spacing-sm) 0 0;
		}

		.highlight:hover {
			border-top-color: var(--color-text);
		}

		/* On mobile, always show summaries */
		.compact-reveal {
			max-height: none;
			padding: 0 0 0.5rem;
		}
	}
</style>
