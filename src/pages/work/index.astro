---
import Base from "../../layouts/Base.astro";

const sections = [
	{
		label: "Development",
		slug: "dev_projects",
		items: [
			{ slug: "molt", title: "Molt", summary: "An ahead-of-time Python-to-WebAssembly compiler with aggressive tree shaking and deforestation.", meta: "Rust, Python, Wasm" },
			{ slug: "crafted-action-pages", title: "Crafted Action Pages", summary: "Campaign action page engine with FEC/state disclaimer compliance, geo-personalized donation asks, and edge A/B testing.", meta: "TypeScript, Astro, Cloudflare Workers, D1" },
		],
	},
];
---

<Base title="Work">
	<main id="main-content" class="page">
		{sections.map((section) => (
			<section style="margin-bottom: var(--spacing-xl)">
				<h2 class="section-label">{section.label}</h2>
				<ul class="item-list" role="list">
					{section.items.map((item) => (
						<li>
							<a href={`/work/${section.slug}/${item.slug}`} class="item-link">
								<span class="item-title">{item.title}</span>
								<span class="item-desc">{item.summary}</span>
								<span class="item-meta">{item.meta}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		))}
	</main>
</Base>
