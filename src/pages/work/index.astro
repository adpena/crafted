---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const sections = [
	{ slug: "dev_projects", label: "Development" },
	{ slug: "design_work", label: "Design" },
	{ slug: "policy_work", label: "Policy" },
	{ slug: "writing", label: "Writing" },
];

const loaded = await Promise.all(
	sections.map(async (section) => {
		try {
			const { entries, cacheHint } = await getEmDashCollection(section.slug);
			return { ...section, entries, cacheHint };
		} catch {
			return { ...section, entries: [], cacheHint: null };
		}
	})
);

const nonEmpty = loaded.filter((s) => s.entries.length > 0);

for (const s of loaded) {
	if (s.cacheHint) try { Astro.cache.set(s.cacheHint); } catch {}
}
---

<Base title="Work">
	<main id="main-content" class="work-page">
		{nonEmpty.length > 0 ? (
			nonEmpty.map((section) => (
				<section class="work-section">
					<h2 class="section-heading">{section.label}</h2>
					<ul class="project-list" role="list">
						{section.entries.map((entry) => (
							<li>
								<a href={`/work/${section.slug}/${entry.id}`} class="project-link">
									<span class="project-name">{entry.data.title}</span>
									{entry.data.summary && (
										<span class="project-summary">{entry.data.summary}</span>
									)}
									{entry.data.stack && (
										<span class="project-meta mono">{entry.data.stack}</span>
									)}
									{entry.data.publication && (
										<span class="project-meta mono">{entry.data.publication}</span>
									)}
									{entry.data.medium && (
										<span class="project-meta mono">{entry.data.medium}</span>
									)}
								</a>
							</li>
						))}
					</ul>
				</section>
			))
		) : (
			<p class="empty">No work yet.</p>
		)}
	</main>
</Base>

<style>
	.work-page {
		max-width: 42rem;
		margin: 0 auto;
		padding: var(--spacing-lg) 0 var(--spacing-2xl);
	}

	.work-section {
		margin-bottom: var(--spacing-xl);
	}

	.section-heading {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-secondary);
		padding-bottom: var(--spacing-sm);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--spacing-md);
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.project-link {
		display: block;
		padding: var(--spacing-sm) 0;
		text-decoration: none;
		color: inherit;
		transition: opacity 150ms ease;
	}

	.project-link:hover {
		opacity: 0.65;
	}

	.project-name {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: 600;
	}

	.project-summary {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		color: var(--color-secondary);
		line-height: 1.5;
		margin-top: 0.15rem;
	}

	.project-meta {
		display: block;
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-top: 0.25rem;
	}

	.empty {
		color: var(--color-secondary);
		text-align: center;
		padding: var(--spacing-3xl) 0;
	}
</style>
