---
import { getEmDashEntry } from "emdash";
import { PortableText, Image } from "emdash/ui";
import Base from "../../../layouts/Base.astro";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const { entry, cacheHint } = await getEmDashEntry("dev", slug);
if (!entry) return Astro.redirect("/404");
try { Astro.cache.set(cacheHint); } catch {}

const d = entry.data;
const hasMoltDemo = slug === "molt";
const hasActionDemo = slug === "crafted-action-pages";
---

<Base title={d.title}>
	<main id="main-content" class={hasMoltDemo || hasActionDemo ? "page page-wide" : "page"}>
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/work">Work</a> / Development / {d.title}
		</nav>

		<h1 class="page-title">{d.title}</h1>
		{d.summary && <p class="page-summary">{d.summary}</p>}

		<dl class="meta-grid">
			{d.stack && <><dt>Stack</dt><dd>{d.stack}</dd></>}
			{d.year && <><dt>Year</dt><dd>{d.year}</dd></>}
			{d.project_status && <><dt>Status</dt><dd>{d.project_status}</dd></>}
			{d.repo_url && <><dt>Repo</dt><dd><a href={d.repo_url} target="_blank" rel="noopener noreferrer">{d.repo_url.replace("https://github.com/", "")}</a></dd></>}
			{d.live_url && <><dt>Demo</dt><dd><a href={d.live_url} target="_blank" rel="noopener noreferrer">Live</a></dd></>}
		</dl>

		{hasMoltDemo && (
			<section class="demo-embed" aria-label="Live demo">
				<iframe
					src="/demo/molt?embed=stacked"
					title="Molt Mandelbrot demo — Python compiled to WebAssembly"
					loading="lazy"
				></iframe>
			</section>
		)}

		{hasActionDemo && (
			<section class="demo-embed" aria-label="Live demo">
				<iframe
					src="/action/fund-public-schools?embed=1"
					title="Campaign Action Pages demo — petition with fundraise follow-up"
					loading="lazy"
					style="min-height:600px"
				></iframe>
			</section>
		)}

		{d.featured_image && (
			<div class="hero-image"><Image image={d.featured_image} /></div>
		)}

		<div class="prose"><PortableText value={d.content} /></div>
	</main>
</Base>

<style>
	.page-wide {
		max-width: 64rem;
	}

	.page-wide .prose {
		max-width: 42rem;
		margin: 0 auto;
	}

	.page-wide .meta-grid {
		max-width: 42rem;
	}

	.page-wide .page-title,
	.page-wide .page-summary,
	.page-wide .breadcrumb {
		max-width: 42rem;
	}

	.demo-embed {
		margin-bottom: var(--spacing-xl);
		margin-left: -4rem;
		margin-right: -4rem;
	}

	.demo-embed iframe {
		width: 100%;
		height: 40rem;
		border: 1px solid var(--color-border);
		background: var(--color-bg);
	}

	@media (max-width: 1100px) {
		.demo-embed {
			margin-left: 0;
			margin-right: 0;
		}
	}

	@media (max-width: 768px) {
		.page-wide {
			max-width: 100%;
			padding-left: var(--content-padding);
			padding-right: var(--content-padding);
		}

		.demo-embed {
			margin-left: 0;
			margin-right: 0;
		}

		.demo-embed iframe {
			height: 60vh;
			min-height: 20rem;
		}
	}

	@media (max-width: 480px) {
		.demo-embed iframe {
			height: 50vh;
			min-height: 16rem;
		}
	}
</style>
