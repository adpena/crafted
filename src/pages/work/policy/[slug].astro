---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../../layouts/Base.astro";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const { entry, cacheHint } = await getEmDashEntry("policy", slug);
if (!entry) return Astro.redirect("/404");
try { Astro.cache.set(cacheHint); } catch {}

// emdash returns entry.data as `unknown` (collection schemas are dynamic);
// narrow to the expected shape here so the template can read fields
// without fighting the type system on every access.
const d = entry.data as {
	title?: string;
	summary?: string;
	publication?: string;
	date?: string;
	topic?: string;
	coauthors?: string;
	link?: string;
	pdf_url?: string;
	content?: unknown;
};
const dateStr = d.date ? new Date(d.date).toLocaleDateString("en-US", { year: "numeric", month: "long" }) : null;
const ogImage = `/og/${slug}.png`;
---

<Base title={d.title} description={d.summary} image={ogImage}>
	<main id="main-content" class="page">
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/work">Work</a> / Policy / {d.title}
		</nav>

		<h1 class="page-title">{d.title}</h1>
		{d.summary && <p class="page-summary">{d.summary}</p>}

		<dl class="meta-grid">
			{d.publication && <><dt>Published in</dt><dd>{d.publication}</dd></>}
			{dateStr && <><dt>Date</dt><dd>{dateStr}</dd></>}
			{d.topic && <><dt>Topic</dt><dd>{d.topic}</dd></>}
			{d.coauthors && <><dt>Co-authors</dt><dd>{d.coauthors}</dd></>}
			{d.link && <><dt>Link</dt><dd><a href={d.link} target="_blank" rel="noopener noreferrer">Read</a></dd></>}
			{d.pdf_url && <><dt>PDF</dt><dd><a href={d.pdf_url} target="_blank" rel="noopener noreferrer">Download</a></dd></>}
		</dl>

		<div class="prose"><PortableText value={d.content} /></div>
	</main>
</Base>
