---
import { getEmDashEntry, getEntryTerms } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import ProjectSidebar from "../../components/ProjectSidebar.astro";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: project, cacheHint } = await getEmDashEntry("projects", slug);

if (!project) {
	return Astro.redirect("/404");
}

try {
	Astro.cache.set(cacheHint);
} catch {}

const tags = await getEntryTerms("projects", project.data.id, "tag");
const stack = tags.map((t) => t.label);

function getImageSrc(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	return typeof image.src === "string" ? image.src : undefined;
}
---

<Base
	title={project.data.title}
	description={project.data.summary}
	image={getImageSrc(project.data.featured_image)}
	type="article"
>
	<main class="project-page">
		<div class="container">
			<nav aria-label="Breadcrumb" class="breadcrumb">
				<a href="/">Home</a>
				<span aria-hidden="true">/</span>
				<a href="/work">Work</a>
				<span aria-hidden="true">/</span>
				<span aria-current="page">{project.data.title}</span>
			</nav>

			<header class="project-header">
				<h1 class="project-title" {...project.edit.title}>
					{project.data.title}
				</h1>
				{project.data.summary && (
					<p class="project-summary" {...project.edit.summary}>
						{project.data.summary}
					</p>
				)}
			</header>

			{project.data.featured_image && (
				<div class="project-hero" {...project.edit.featured_image}>
					<Image image={project.data.featured_image} />
				</div>
			)}

			<div class="project-layout">
				<div class="project-content">
					<PortableText value={project.data.content} />
				</div>

				<ProjectSidebar
					stack={stack}
					url={project.data.url}
					year={project.data.year}
					status="Active"
				/>
			</div>
		</div>
	</main>
</Base>

<style>
	.project-page {
		padding: var(--spacing-xl) 0 var(--spacing-4xl);
	}

	.breadcrumb {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-bottom: var(--spacing-2xl);
		display: flex;
		gap: var(--spacing-sm);
	}

	.breadcrumb a {
		color: var(--color-secondary);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.breadcrumb a:hover {
		color: var(--color-text);
	}

	.breadcrumb [aria-current="page"] {
		color: var(--color-text);
	}

	.project-header {
		margin-bottom: var(--spacing-2xl);
	}

	.project-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 700;
		line-height: 1.1;
		margin-bottom: var(--spacing-md);
	}

	.project-summary {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		color: var(--color-secondary);
		line-height: 1.55;
		max-width: 40rem;
	}

	.project-hero {
		margin-bottom: var(--spacing-2xl);
	}

	.project-hero :global(img) {
		width: 100%;
		height: auto;
	}

	.project-layout {
		display: grid;
		grid-template-columns: 1fr 16rem;
		gap: var(--spacing-3xl);
		align-items: start;
	}

	.project-content {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		line-height: 1.7;
	}

	.project-content :global(p) {
		margin-bottom: 1.5em;
	}

	.project-content :global(h2) {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 700;
		margin-top: 2.5em;
		margin-bottom: 0.75em;
	}

	.project-content :global(h3) {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 700;
		margin-top: 2em;
		margin-bottom: 0.5em;
	}

	.project-content :global(blockquote) {
		margin: 2em 0;
		padding-left: var(--spacing-xl);
		border-left: 2px solid var(--color-border);
		color: var(--color-secondary);
		font-style: italic;
		font-size: var(--font-size-lg);
	}

	.project-content :global(ul),
	.project-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.25em;
	}

	.project-content :global(li) {
		margin-bottom: 0.5em;
	}

	.project-content :global(img) {
		margin: 2em 0;
	}

	@media (max-width: 768px) {
		.project-layout {
			grid-template-columns: 1fr;
			gap: var(--spacing-2xl);
		}

		.project-title {
			font-size: var(--font-size-2xl);
		}
	}
</style>
