---
import { getEmDashEntry, getEntryTerms } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import ProjectSidebar from "../../components/ProjectSidebar.astro";
import MetricsBanner from "../../components/MetricsBanner.tsx";
import TabbedContent from "../../components/TabbedContent.tsx";
import ResizablePanel from "../../components/ResizablePanel.tsx";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: project, cacheHint } = await getEmDashEntry("projects", slug);

if (!project) {
	return Astro.redirect("/404");
}

try {
	Astro.cache.set(cacheHint);
} catch {}

const tags = await getEntryTerms("projects", project.data.id, "tag");
const stack = tags.map((t) => t.label);

function getImageSrc(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	return typeof image.src === "string" ? image.src : undefined;
}

/* ── Flagship configuration ── */
const FLAGSHIP_SLUGS = ["molt", "crafted-action-pages"];
const isFlagship = FLAGSHIP_SLUGS.includes(slug);

const flagshipMetrics: Record<string, { value: string; label: string }[]> = {
	molt: [
		{ value: "12,000", label: "Lines refactored" },
		{ value: "3.2s", label: "Avg. build time" },
		{ value: "94", label: "Lighthouse score" },
		{ value: "0", label: "Runtime deps" },
	],
	"crafted-action-pages": [
		{ value: "48", label: "Action templates" },
		{ value: "1.8s", label: "Time to interactive" },
		{ value: "100%", label: "A11y compliance" },
		{ value: "5", label: "Integrations" },
	],
};
---

<Base
	title={project.data.title}
	description={project.data.summary}
	image={getImageSrc(project.data.featured_image)}
	type="article"
>
	<main class="project-page">
		<div class="container">
			<nav aria-label="Breadcrumb" class="breadcrumb">
				<a href="/">Home</a>
				<span aria-hidden="true">/</span>
				<a href="/work">Work</a>
				<span aria-hidden="true">/</span>
				<span aria-current="page">{project.data.title}</span>
			</nav>

			<header class="project-header">
				<h1 class="project-title" transition:name={`project-title-${slug}`} {...project.edit.title}>
					{project.data.title}
				</h1>
				{project.data.summary && (
					<p class="project-summary" {...project.edit.summary}>
						{project.data.summary}
					</p>
				)}
			</header>

			{project.data.featured_image && (
				<div class="project-hero" transition:name={`project-hero-${slug}`} {...project.edit.featured_image}>
					<Image image={project.data.featured_image} />
				</div>
			)}

			{isFlagship && flagshipMetrics[slug] && (
				<MetricsBanner client:visible metrics={flagshipMetrics[slug]} />
			)}

			{isFlagship ? (
				<TabbedContent
					client:visible
					tabs={[
						{
							label: "Overview",
							content: (
								<div class="project-layout">
									<div class="project-content">
										<PortableText value={project.data.content} />
									</div>
									<ProjectSidebar
										stack={stack}
										url={project.data.url}
										year={project.data.year}
										status="Active"
									/>
								</div>
							),
						},
						{
							label: "Architecture",
							content: (
								<div class="flagship-architecture">
									<h3>System Architecture</h3>
									<p>
										Technical architecture details for {project.data.title}. This section covers the
										design decisions, technology choices, and structural patterns that shape the project.
									</p>
									<p>
										Built with a focus on performance, maintainability, and developer experience.
										Each layer of the stack was chosen deliberately.
									</p>
								</div>
							),
						},
						{
							label: "Demo",
							content: (
								<ResizablePanel
									client:visible
									initialSplit={45}
									left={
										<div>
											<h3 style={{ fontFamily: "var(--font-serif)", fontWeight: 700, fontSize: "var(--font-size-lg)", marginBottom: "0.75rem" }}>
												Live Preview
											</h3>
											<p>
												Interact with the resize handle to explore this split-panel layout.
												The left panel holds descriptive content while the right panel
												can display diagrams, code, or live previews.
											</p>
											<p>
												Drag the divider or use arrow keys when focused on the handle
												to adjust the split between 20% and 80%.
											</p>
										</div>
									}
									right={
										<div>
											<pre style={{ margin: 0, background: "transparent", padding: 0 }}>
{`// ${project.data.title}
// Interactive demo placeholder

┌─────────────────────┐
│                     │
│   ${slug}           │
│   ──────            │
│                     │
│   Ready for         │
│   live content      │
│                     │
└─────────────────────┘`}
											</pre>
										</div>
									}
								/>
							),
						},
					]}
				/>
			) : (
				<div class="project-layout">
					<div class="project-content">
						<PortableText value={project.data.content} />
					</div>

					<ProjectSidebar
						stack={stack}
						url={project.data.url}
						year={project.data.year}
						status="Active"
					/>
				</div>
			)}
		</div>
	</main>
</Base>

<style>
	.project-page {
		padding: var(--spacing-xl) 0 var(--spacing-4xl);
	}

	.breadcrumb {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-bottom: var(--spacing-2xl);
		display: flex;
		gap: var(--spacing-sm);
	}

	.breadcrumb a {
		color: var(--color-secondary);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.breadcrumb a:hover {
		color: var(--color-text);
	}

	.breadcrumb [aria-current="page"] {
		color: var(--color-text);
	}

	.project-header {
		margin-bottom: var(--spacing-2xl);
	}

	.project-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 700;
		line-height: 1.1;
		margin-bottom: var(--spacing-md);
	}

	.project-summary {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		color: var(--color-secondary);
		line-height: 1.55;
		max-width: 40rem;
	}

	.project-hero {
		margin-bottom: var(--spacing-2xl);
	}

	.project-hero :global(img) {
		width: 100%;
		height: auto;
	}

	.project-layout {
		display: grid;
		grid-template-columns: 1fr 16rem;
		gap: var(--spacing-3xl);
		align-items: start;
	}

	.project-content {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		line-height: 1.7;
	}

	.project-content :global(p) {
		margin-bottom: 1.5em;
	}

	.project-content :global(h2) {
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 700;
		margin-top: 2.5em;
		margin-bottom: 0.75em;
	}

	.project-content :global(h3) {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: 700;
		margin-top: 2em;
		margin-bottom: 0.5em;
	}

	.project-content :global(blockquote) {
		margin: 2em 0;
		padding-left: var(--spacing-xl);
		border-left: 2px solid var(--color-border);
		color: var(--color-secondary);
		font-style: italic;
		font-size: var(--font-size-lg);
	}

	.project-content :global(ul),
	.project-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.25em;
	}

	.project-content :global(li) {
		margin-bottom: 0.5em;
	}

	.project-content :global(img) {
		margin: 2em 0;
	}

	.flagship-architecture {
		max-width: 40rem;
	}

	.flagship-architecture h3 {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: var(--font-size-lg);
		margin-bottom: 0.75rem;
	}

	.flagship-architecture p {
		margin-bottom: 1em;
		color: var(--color-text);
	}

	@media (max-width: 768px) {
		.project-layout {
			grid-template-columns: 1fr;
			gap: var(--spacing-2xl);
		}

		.project-title {
			font-size: var(--font-size-2xl);
		}
	}
</style>
