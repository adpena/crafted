---
import { getEmDashEntry } from "emdash";
import { PortableText, Image } from "emdash/ui";
import Base from "../../../layouts/Base.astro";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const { entry, cacheHint } = await getEmDashEntry("dev_projects", slug);
if (!entry) return Astro.redirect("/404");
try { Astro.cache.set(cacheHint); } catch {}

const d = entry.data;
const hasMoltDemo = slug === "molt";
---

<Base title={d.title}>
	<main id="main-content" class={hasMoltDemo ? "page page-wide" : "page"}>
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/work">Work</a> / Development / {d.title}
		</nav>

		<h1 class="page-title">{d.title}</h1>
		{d.summary && <p class="page-summary">{d.summary}</p>}

		<dl class="meta-grid">
			{d.stack && <><dt>Stack</dt><dd>{d.stack}</dd></>}
			{d.year && <><dt>Year</dt><dd>{d.year}</dd></>}
			{d.project_status && <><dt>Status</dt><dd>{d.project_status}</dd></>}
			{d.repo_url && <><dt>Repo</dt><dd><a href={d.repo_url} target="_blank" rel="noopener noreferrer">{d.repo_url.replace("https://github.com/", "")}</a></dd></>}
			{d.live_url && <><dt>Demo</dt><dd><a href={d.live_url} target="_blank" rel="noopener noreferrer">Live</a></dd></>}
		</dl>

		{hasMoltDemo && (
			<Fragment>
				<section class="demo-embed" aria-label="Live demo">
					<iframe
						src="/demo/molt?embed=1"
						title="Molt Mandelbrot demo — Python compiled to WebAssembly"
						loading="lazy"
					></iframe>
				</section>
				<details class="demo-source" open>
					<summary class="section-label" style="cursor:pointer; margin-bottom: var(--spacing-sm)">mandelbrot.py</summary>
					<pre class="demo-code" id="molt-source"><code>Loading...</code></pre>
				</details>
				<script>
					fetch('/molt-demo/mandelbrot.py')
						.then(r => r.text())
						.then(src => {
							const el = document.getElementById('molt-source');
							if (el) el.innerHTML = '<code>' + src.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</code>';
						});
				</script>
			</Fragment>
		)}

		{d.featured_image && (
			<div class="hero-image"><Image image={d.featured_image} /></div>
		)}

		<div class="prose"><PortableText value={d.content} /></div>
	</main>
</Base>

<style>
	.page-wide {
		max-width: 64rem;
	}

	.page-wide .prose {
		max-width: 42rem;
		margin: 0 auto;
	}

	.page-wide .meta-grid {
		max-width: 42rem;
	}

	.page-wide .page-title,
	.page-wide .page-summary,
	.page-wide .breadcrumb {
		max-width: 42rem;
	}

	.demo-embed {
		margin-bottom: var(--spacing-xl);
		margin-left: -4rem;
		margin-right: -4rem;
	}

	.demo-embed iframe {
		width: 100%;
		aspect-ratio: 16 / 9;
		border: none;
		background: var(--color-text);
	}

	@media (max-width: 1100px) {
		.demo-embed {
			margin-left: 0;
			margin-right: 0;
		}
	}

	.demo-source {
		margin-bottom: var(--spacing-xl);
	}

	.demo-code {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		line-height: 1.6;
		background: var(--color-surface);
		color: var(--color-text);
		padding: var(--spacing-md) var(--spacing-lg);
		overflow-x: auto;
		border: 1px solid var(--color-border);
	}

	.demo-code code {
		background: none;
		padding: 0;
		font-size: inherit;
	}

	@media (max-width: 768px) {
		.demo-embed iframe {
			height: 70vh;
		}
	}
</style>
