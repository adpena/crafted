---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "about");
try { Astro.cache.set(cacheHint); } catch {}
---

<Base title="About">
	<main id="main-content" class="page">
		<div class="prose">
			{page?.data?.content ? (
				<PortableText value={page.data.content} />
			) : (
				<Fragment>
					<p>
						I build tools for progressive campaigns, public education advocates,
						and labor organizations.
					</p>
					<p>
						Before writing code full-time, I spent six years in the Texas
						Legislature. That background shapes how I build software.
					</p>
				</Fragment>
			)}
		</div>

		<aside class="about-cta">
			<h2 class="section-label">Get in touch</h2>
			<a href="/contact" class="btn">Send a message</a>
		</aside>
	</main>
</Base>

<style>
	.about-cta {
		margin-top: var(--spacing-2xl);
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-border);
	}

	.about-cta .btn {
		margin-top: var(--spacing-sm);
	}
</style>
