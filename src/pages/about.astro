---
import Base from "../layouts/Base.astro";
---

<Base title="About">
	<main id="main-content" class="page about-page">
		<div class="terminal">
			<div class="line">$ whoami</div>
			<div class="line" data-type="alejandro peña">&nbsp;</div>
			<div class="line" data-type="austin, tx">&nbsp;</div>
			<div class="line">&nbsp;</div>
			<div class="line" data-type="building tools for people who build things.">&nbsp;</div>
		</div>
		<a href="/contact" class="btn about-btn" id="about-cta" style="visibility:hidden">Get in touch</a>
	</main>
</Base>

<style>
	.about-page {
		min-height: 50vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.terminal {
		font-family: var(--font-mono);
		font-size: var(--font-size-base);
		line-height: 1.8;
		margin-bottom: var(--spacing-xl);
	}

	.line {
		white-space: pre;
		min-height: 1.8em;
	}

	.about-btn {
		align-self: flex-start;
	}

	.cursor::after {
		content: "_";
		animation: blink 1s step-end infinite;
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor::after { animation: none; }
	}
</style>

<script>
	const lines = Array.from(document.querySelectorAll('[data-type]'));
	const cta = document.getElementById('about-cta');
	const charDelay = 35;
	const lineGap = 250;
	let lineIndex = 0;

	function typeLine() {
		if (lineIndex >= lines.length) {
			cta!.style.visibility = 'visible';
			return;
		}

		const el = lines[lineIndex];
		const text = el.getAttribute('data-type') || '';
		let ci = 0;

		el.textContent = '';
		function typeChar() {
			if (ci < text.length) {
				el.textContent = text.slice(0, ci + 1);
				ci++;
				setTimeout(typeChar, charDelay);
			} else {
				lineIndex++;
				setTimeout(typeLine, lineGap);
			}
		}

		typeChar();
	}

	setTimeout(typeLine, 600);
</script>
