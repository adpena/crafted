---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "about");

try { Astro.cache.set(cacheHint); } catch {}
---

<Base title="About">
	<main id="main-content" class="about-page">
		<div class="about-content" {...page?.edit?.content}>
			{page?.data?.content ? (
				<PortableText value={page.data.content} />
			) : (
				<Fragment>
					<p>
						Systems engineer and compiler author. I build infrastructure
						that makes other things work better.
					</p>
					<p>
						Currently focused on Python-to-Wasm compilation and campaign
						technology for progressive causes. Previously: Django, WordPress,
						frontend web development.
					</p>
					<p>
						Looking for my next role at the intersection of development,
						design, policy, and politics.
					</p>
				</Fragment>
			)}
		</div>

		<aside class="about-sidebar">
			<div class="sidebar-section">
				<h2>Get in touch</h2>
				<p><a href="/contact">Send a message</a></p>
			</div>
		</aside>
	</main>
</Base>

<style>
	.about-page {
		max-width: 42rem;
		margin: 0 auto;
		padding: var(--spacing-xl) 0 var(--spacing-3xl);
	}

	.about-content {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		line-height: 1.8;
	}

	.about-content :global(p) {
		margin-bottom: 1.25em;
	}

	.about-sidebar {
		margin-top: var(--spacing-2xl);
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-border);
	}

	.sidebar-section h2 {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-secondary);
		margin-bottom: var(--spacing-sm);
	}

	.sidebar-section a {
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		color: var(--color-text);
	}
</style>
