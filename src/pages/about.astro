---
import Base from "../layouts/Base.astro";
---

<Base title="About">
	<main id="main-content" class="page about-page">
		<div class="terminal" aria-hidden="true">
			<div class="line">$ whoami</div>
			<div class="line" data-type="alejandro peña">&nbsp;</div>
			<div class="line" data-type="austin, tx">&nbsp;</div>
		</div>
		<p class="visually-hidden">alejandro peña — austin, tx</p>
		<a href="/contact" class="btn about-btn" id="about-cta" style="opacity:0;visibility:hidden;transition:opacity 600ms ease,visibility 0s linear 0s;animation:none">Get in touch</a>
	</main>
</Base>

<style>
	.about-page {
		min-height: 50vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.terminal {
		font-family: var(--font-mono);
		font-size: var(--font-size-base);
		line-height: 1.8;
		margin-bottom: var(--spacing-xl);
	}

	.line {
		white-space: pre-wrap;
		word-break: break-word;
		min-height: 1.8em;
	}

	.about-btn {
		align-self: center;
		font-size: var(--font-size-sm);
		padding: 0.6rem var(--spacing-xl);
	}

	.cursor::after {
		content: "_";
		animation: blink 1s step-end infinite;
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	@media (max-width: 480px) {
		.about-page {
			min-height: 30vh;
		}

		.terminal {
			font-size: var(--font-size-sm);
		}

		.about-btn {
			min-height: 44px;
			display: inline-flex;
			align-items: center;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor::after { animation: none; }
	}
</style>

<script>
	const lines = Array.from(document.querySelectorAll('[data-type]'));
	const cta = document.getElementById('about-cta');

	function showCta() {
		if (!cta) return;
		cta.style.visibility = 'visible';
		cta.style.opacity = '1';
	}

	// Respect reduced motion — show content instantly
	if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		lines.forEach(el => { el.textContent = el.getAttribute('data-type') || ''; });
		showCta();
	} else {
		const charDelay = 35;
		const lineGap = 250;
		let lineIndex = 0;

		function typeLine() {
			if (lineIndex >= lines.length) { showCta(); return; }

			const el = lines[lineIndex];
			const text = el.getAttribute('data-type') || '';
			let ci = 0;

			el.textContent = '';
			el.classList.add('cursor');

			function typeChar() {
				if (ci < text.length) {
					el.textContent = text.slice(0, ci + 1);
					ci++;
					setTimeout(typeChar, charDelay);
				} else {
					el.classList.remove('cursor');
					lineIndex++;
					setTimeout(typeLine, lineGap);
				}
			}

			typeChar();
		}

		setTimeout(typeLine, 600);
	}
</script>
