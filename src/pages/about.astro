---
import Base from "../layouts/Base.astro";
---

<Base title="About">
	<main id="main-content" class="page about-page">
		<div class="terminal">
			<div class="line">$ whoami</div>
			<div class="line hidden" data-line="0">alejandro peña</div>
			<div class="line hidden" data-line="1">austin, tx</div>
			<div class="line hidden" data-line="2">&nbsp;</div>
			<div class="line hidden" data-line="3">building tools for people who build things.</div>
		</div>
		<a href="/contact" class="btn about-btn hidden" data-line="4">Get in touch</a>
	</main>
</Base>

<style>
	.about-page {
		min-height: 50vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.terminal {
		font-family: var(--font-mono);
		font-size: var(--font-size-base);
		line-height: 1.8;
		margin-bottom: var(--spacing-xl);
	}

	.line {
		white-space: pre;
	}

	.hidden {
		visibility: hidden;
	}

	.revealed {
		visibility: visible;
	}

	.about-btn {
		align-self: flex-start;
	}

	@media (prefers-reduced-motion: reduce) {
		.hidden { visibility: visible; }
	}
</style>

<script>
	const lines = document.querySelectorAll('[data-line]');
	const delays = [800, 1200, 1500, 1800, 2400];

	lines.forEach((el, i) => {
		setTimeout(() => {
			el.classList.remove('hidden');
			el.classList.add('revealed');
		}, delays[i] ?? 800 + i * 400);
	});
</script>
