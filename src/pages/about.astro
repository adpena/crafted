---
import Base from "../layouts/Base.astro";
---

<Base title="About">
	<main id="main-content" class="page about-placeholder">
		<pre class="terminal" id="terminal" aria-label="About">$ whoami
<span class="cursor">_</span></pre>
		<a href="/contact" class="btn">Get in touch</a>
	</main>
</Base>

<style>
	.about-placeholder {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		min-height: 50vh;
	}

	.terminal {
		font-family: var(--font-mono);
		font-size: var(--font-size-base);
		color: var(--color-text);
		background: none;
		padding: 0;
		margin-bottom: var(--spacing-xl);
		line-height: 1.8;
		white-space: pre-wrap;
	}

	.cursor {
		animation: blink 1s step-end infinite;
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	.about-placeholder .btn {
		opacity: 0;
		animation: enter 600ms ease forwards;
		animation-delay: 3s;
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor { animation: none; }
		.about-placeholder .btn { opacity: 1; animation: none; }
	}
</style>

<script>
	const el = document.getElementById('terminal');
	if (el) {
		const lines = [
			'alejandro peña',
			'austin, tx',
			'',
			'building tools for people who build things.',
		];

		let i = 0;
		let charIndex = 0;
		const delay = 40;
		const lineDelay = 300;

		const cursor = '<span class="cursor">_</span>';
		let output = '$ whoami\n';

		function removeCursor() {
			el.innerHTML = el.innerHTML.replace(cursor, '');
		}

		function setCursor() {
			removeCursor();
			el.innerHTML = el.innerHTML + cursor;
		}

		function type() {
			if (i >= lines.length) {
				removeCursor();
				return;
			}

			const line = lines[i];

			if (charIndex < line.length) {
				removeCursor();
				output += line[charIndex];
				el.textContent = output;
				setCursor();
				charIndex++;
				setTimeout(type, delay);
			} else {
				output += '\n';
				charIndex = 0;
				i++;
				setTimeout(type, lineDelay);
			}
		}

		setTimeout(type, 800);
	}
</script>
