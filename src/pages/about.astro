---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "about");
try { Astro.cache.set(cacheHint); } catch {}
---

<Base title="About">
	<main id="main-content" class="page">
		<div class="prose">
			{page?.data?.content ? (
				<PortableText value={page.data.content} />
			) : (
				<Fragment>
					<p>
						Systems engineer and compiler author. I build infrastructure
						that makes other things work better.
					</p>
					<p>
						Currently focused on Python-to-Wasm compilation and campaign
						technology for progressive causes. Previously: Django, WordPress,
						frontend web development.
					</p>
					<p>
						Looking for my next role at the intersection of development,
						design, policy, and politics.
					</p>
				</Fragment>
			)}
		</div>

		<aside style="margin-top: var(--spacing-2xl); padding-top: var(--spacing-lg); border-top: 1px solid var(--color-border)">
			<h2 class="section-label">Get in touch</h2>
			<a href="/contact">Send a message</a>
		</aside>
	</main>
</Base>
