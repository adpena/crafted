---
import { getEmDashCollection } from "emdash";
import { env } from "cloudflare:workers";
import Base from "../layouts/Base.astro";
import WorkListing from "../components/WorkListing.tsx";
import type { WorkSection, WorkEntry } from "../components/WorkListing.tsx";

const collectionDefs = [
	{ slug: "dev", label: "Development" },
	{ slug: "design", label: "Design" },
	{ slug: "policy", label: "Policy" },
	{ slug: "writing", label: "Writing" },
];

// Pinned entries float to top; everything else sorts newest-first.
const PIN: Record<string, number> = {
	"molt": 1,
	"action-pages": 2,
};

function entryTime(e: { data: Record<string, any> }): number {
	if (e.data.date) return new Date(e.data.date).getTime();
	return parseInt(e.data.year ?? "0", 10) * 1e10;
}

function serializeEntries(entries: any[], slug: string, label: string): WorkSection | null {
	if (!entries?.length) return null;
	const sorted = [...entries].sort((a, b) => {
		const pa = PIN[a.id] ?? Infinity;
		const pb = PIN[b.id] ?? Infinity;
		if (pa !== pb) return pa - pb;
		return entryTime(b) - entryTime(a);
	});

	return {
		slug,
		label,
		entries: sorted.map((e) => ({
			id: e.id,
			slug: e.id,
			editRef: e.edit?.["data-emdash-ref"] ?? "",
			data: {
				title: e.data.title ?? "",
				summary: e.data.summary ?? "",
				stack: e.data.stack ?? "",
				publication: e.data.publication ?? "",
				medium: e.data.medium ?? "",
				year: e.data.year ?? "",
				date: e.data.date ?? "",
			},
			fieldRefs: {
				title: e.edit?.title?.["data-emdash-ref"] ?? "",
				summary: e.edit?.summary?.["data-emdash-ref"] ?? "",
			},
		})),
	};
}

// KV edge cache: serve sections from the nearest PoP (~20ms) instead
// of querying D1 (~584ms). TTL keeps content fresh within 60 seconds.
const CACHE_KEY = "work-sections-v1";
const CACHE_TTL = 60;

let sections: WorkSection[] = [];
const kv = (env as any).CACHE as KVNamespace | undefined;

// Try KV cache first
let cached: string | null = null;
try { cached = kv ? await kv.get(CACHE_KEY) : null; } catch {}

if (cached) {
	sections = JSON.parse(cached);
} else {
	// Cache miss — query D1 in parallel
	const results = await Promise.all(
		collectionDefs.map(async (def) => {
			try {
				const result = await getEmDashCollection(def.slug);
				if (result.cacheHint) {
					try { Astro.cache.set(result.cacheHint); } catch {}
				}
				return serializeEntries(result.entries, def.slug, def.label);
			} catch {}
			return null;
		})
	);

	sections = results.filter((s): s is WorkSection => s !== null);

	// Store in KV for subsequent requests
	if (kv && sections.length > 0) {
		try { await kv.put(CACHE_KEY, JSON.stringify(sections), { expirationTtl: CACHE_TTL }); } catch {}
	}
}

const highlights = [
	{ title: "Molt", desc: "Python-to-Wasm compiler", href: "/work/dev/molt", tag: "Featured" },
	{ title: "Lost Decade", desc: "Analysis → 11% raise for educators", href: "/work/policy/the-lost-decade-and-a-half", tag: "Impact" },
	{ title: "Action Pages", desc: "Live campaign page engine", href: "/work/dev/action-pages", tag: "Demo" },
	{ title: "Respect Campaign", desc: "District-level interactive map", href: "/work/design/respect-campaign-map", tag: "Featured" },
	{ title: "Public Ed Data", desc: "TX education data platform (3 repos)", href: "/work/dev/data-for-public-education", tag: "OSS" },
];
---

<Base>
	<main id="main-content" class="work-layout">
		<WorkListing sections={sections} client:load />

		<aside class="work-sidebar" aria-label="Highlighted projects">
			<h2 class="section-label">Highlights</h2>
			<nav class="highlights">
				{highlights.map((h) => (
					<a href={h.href} class="highlight">
						<span class="highlight-tag">{h.tag}</span>
						<span class="highlight-title">{h.title}</span>
						<span class="highlight-desc">{h.desc}</span>
					</a>
				))}
			</nav>
		</aside>
	</main>
</Base>

<script>
	// Defer scroll-fade init until after React island hydrates
	requestAnimationFrame(() => {
		const sidebar = document.querySelector('.work-sidebar');
		const scroller = document.querySelector('.highlights');
		if (sidebar && scroller) {
			const update = () => {
				const { scrollLeft, scrollWidth, clientWidth } = scroller;
				sidebar.classList.toggle('scrolled-start', scrollLeft > 4);
				sidebar.classList.toggle('scrolled-end', scrollLeft + clientWidth >= scrollWidth - 4);
			};
			scroller.addEventListener('scroll', update, { passive: true });
			update();
		}
	});
</script>
