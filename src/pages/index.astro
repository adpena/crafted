---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";

import FeaturedProject from "../components/FeaturedProject.astro";
import ProjectCard from "../components/ProjectCard.astro";
import StatusBar from "../components/StatusBar.astro";

const { entries: projects, cacheHint } =
	await getEmDashCollection("projects");

try { Astro.cache.set(cacheHint); } catch {}

const sorted = projects.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const featured = sorted[0];
const latest = sorted.slice(1);
---

<Base>
	<main id="main-content" class="homepage">
		<div class="container">
			{featured ? (
				<div class="columns">
					<section aria-label="Featured project" class="col-featured">
						<FeaturedProject
							title={featured.data.title ?? "Untitled"}
							summary={featured.data.summary}
							href={`/work/${featured.id}`}
						/>
					</section>

					<div class="col-divider" aria-hidden="true" />

					<section aria-label="Latest projects" class="col-latest">
						<span class="section-label">Latest</span>
						<div class="latest-list">
							{latest.map((project) => (
								<ProjectCard
									title={project.data.title ?? "Untitled"}
									summary={project.data.summary}
									href={`/work/${project.id}`}
								/>
							))}
						</div>
					</section>
				</div>
			) : (
				<section class="empty-state">
					<h2>No projects yet</h2>
					<p>Add your first project in the admin panel.</p>
					<a href="/_emdash/admin/content/projects/new" class="empty-link">
						Add a project
					</a>
				</section>
			)}
		</div>
	</main>

	<StatusBar
		items={[
			{ label: "built with emdash (WordPress at the edge) + astro + cloudflare workers + d1 + r2" },
			{ label: "open to work" },
		]}
	/>
</Base>

<style>
	.homepage {
		padding: var(--spacing-2xl) 0;
	}

	.columns {
		display: grid;
		grid-template-columns: 1fr 1px 1fr;
		gap: var(--spacing-xl);
	}

	.col-divider {
		background: var(--color-border);
	}

	.section-label {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-secondary);
		margin-bottom: var(--spacing-md);
	}

	.latest-list {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-md);
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-4xl) 0;
	}

	.empty-state h2 {
		font-size: var(--font-size-xl);
		margin-bottom: var(--spacing-sm);
	}

	.empty-state p {
		color: var(--color-secondary);
		margin-bottom: var(--spacing-lg);
	}

	.empty-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-secondary);
	}

	@media (max-width: 768px) {
		.columns {
			grid-template-columns: 1fr;
			gap: var(--spacing-lg);
		}

		.col-divider {
			height: 1px;
		}
	}
</style>
