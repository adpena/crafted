---
import Base from "../layouts/Base.astro";

// TODO: Real CSRF protection (double-submit cookie or signed token) + Cloudflare Turnstile
// must be implemented before this form sends data anywhere meaningful.
// On Cloudflare Workers the primary CSRF defense is SameSite=Strict cookies;
// Turnstile adds bot protection on top.

let formStatus: "idle" | "success" | "error" = "idle";
let formMessage = "";

if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();
		const name = formData.get("name")?.toString() || "";
		const email = formData.get("email")?.toString() || "";
		const message = formData.get("message")?.toString() || "";

		if (!name || !email || !message) {
			formStatus = "error";
			formMessage = "Please fill in all fields.";
		} else if (!email.includes("@")) {
			formStatus = "error";
			formMessage = "Please enter a valid email address.";
		} else {
			console.log("Contact form submission:", { name, email, message });
			formStatus = "success";
			formMessage = "Message sent. I'll be in touch.";
		}
	} catch {
		formStatus = "error";
		formMessage = "Something went wrong. Please try again.";
	}
}
---

<Base title="Contact">
	<main id="main-content" class="contact-page">
		<div class="contact-layout">
			<div class="contact-main">
				{formStatus === "success" ? (
					<div class="contact-success">
						<p>{formMessage}</p>
						<a href="/contact" class="btn">Send another</a>
					</div>
				) : (
					<form method="POST" novalidate class="contact-form">
						{formStatus === "error" && (
							<div role="alert" class="form-error">
								{formMessage}
							</div>
						)}

						<div class="form-field">
							<label for="name">Name</label>
							<input type="text" id="name" name="name" required aria-required="true" autocomplete="name" />
						</div>

						<div class="form-field">
							<label for="email">Email</label>
							<input type="email" id="email" name="email" required aria-required="true" autocomplete="email" />
						</div>

						<div class="form-field">
							<label for="message">Message</label>
							<textarea id="message" name="message" required aria-required="true" rows="8"></textarea>
						</div>

						<button type="submit" class="btn">Send</button>
					</form>
				)}
			</div>

			<aside class="contact-aside">
				<div class="aside-section">
					<h2 class="section-label">Direct</h2>
					<a href="mailto:adpena@gmail.com" class="aside-link">adpena@gmail.com</a>
				</div>
				<div class="aside-section">
					<h2 class="section-label">Elsewhere</h2>
					<a href="https://github.com/adpena" class="aside-link" target="_blank" rel="noopener noreferrer">GitHub</a>
					<a href="https://twitter.com/adpenatx" class="aside-link" target="_blank" rel="noopener noreferrer">Twitter</a>
					<a href="https://linkedin.com/in/adpena" class="aside-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
				</div>
			</aside>
		</div>
	</main>
</Base>

<style>
	.contact-page {
		max-width: 56rem;
		margin: 0 auto;
		padding: var(--spacing-xl) var(--content-padding) var(--spacing-2xl);
	}

	.contact-layout {
		display: grid;
		grid-template-columns: 1fr 14rem;
		gap: var(--spacing-2xl);
		align-items: start;
	}

	.contact-form {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-md) var(--spacing-lg);
	}

	.contact-form .form-field:last-of-type {
		grid-column: 1 / -1;
	}

	.contact-form .btn {
		grid-column: 1;
		justify-self: start;
		margin-top: var(--spacing-sm);
	}

	.form-error {
		grid-column: 1 / -1;
		border-left: 2px solid var(--color-error);
		padding-left: var(--spacing-md);
		color: var(--color-error);
		font-size: var(--font-size-sm);
	}

	.contact-aside {
		position: sticky;
		top: var(--spacing-lg);
	}

	.aside-section {
		margin-bottom: var(--spacing-lg);
	}

	.aside-link {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-secondary);
		text-decoration: none;
		line-height: 1.8;
		transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.aside-link:hover {
		color: var(--color-text);
	}

	.contact-success .btn {
		margin-top: var(--spacing-md);
	}

	@media (max-width: 768px) {
		.contact-layout {
			grid-template-columns: 1fr;
		}

		.contact-form {
			grid-template-columns: 1fr;
		}

		.contact-aside {
			position: static;
			display: flex;
			gap: var(--spacing-xl);
			padding-top: var(--spacing-lg);
			border-top: 1px solid var(--color-border);
		}
	}
</style>
