---
import Base from "../layouts/Base.astro";
import { env } from "cloudflare:workers";
import { notifyAll } from "../lib/notify.ts";

const TURNSTILE_SITE_KEY = "0x4AAAAAACzs7nZ1lZWuydob";

let formStatus: "idle" | "success" | "error" = "idle";
let formMessage = "";
let name = "";
let email = "";
let message = "";

if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();
		name = formData.get("name")?.toString().trim() || "";
		email = formData.get("email")?.toString().trim() || "";
		message = formData.get("message")?.toString().trim() || "";
		const turnstileToken = formData.get("cf-turnstile-response")?.toString() || "";

		// Verify Turnstile — fail closed if secret is not configured
		const turnstileSecret = (env as any).TURNSTILE_SECRET as string | undefined;
		if (!turnstileSecret) {
			formStatus = "error";
			formMessage = "Form is temporarily unavailable. Please email contact@adpena.com.";
		} else if (!turnstileToken) {
			formStatus = "error";
			formMessage = "Verification required. Please try again.";
		} else {
			const ip = Astro.request.headers.get("cf-connecting-ip") || "";
			const verifyRes = await fetch("https://challenges.cloudflare.com/turnstile/v0/siteverify", {
				method: "POST",
				headers: { "Content-Type": "application/x-www-form-urlencoded" },
				body: new URLSearchParams({
					secret: turnstileSecret,
					response: turnstileToken,
					remoteip: ip,
				}),
			});
			const verifyData = await verifyRes.json() as { success: boolean };
			if (!verifyData.success) {
				formStatus = "error";
				formMessage = "Verification failed. Please try again.";
			}
		}

		if (formStatus !== "error") {
			if (!name || !email || !message) {
				formStatus = "error";
				formMessage = "Please fill in all fields.";
			} else if (!email.includes("@") || email.length > 254) {
				formStatus = "error";
				formMessage = "Please enter a valid email address.";
			} else if (name.length > 200 || message.length > 5000) {
				formStatus = "error";
				formMessage = "Input too long.";
			} else {
				const result = await notifyAll(env as any, { name, email, message });
				if (result.sent.length === 0) {
					formStatus = "error";
					formMessage = "Delivery failed. Please email contact@adpena.com directly.";
				} else {
					formStatus = "success";
					formMessage = "Message sent. I'll be in touch.";
				}
			}
		}
	} catch {
		formStatus = "error";
		formMessage = "Something went wrong. Please try again.";
	}
}
---

<Base title="Contact">
	<main id="main-content" class="contact-page">
		<div class="contact-layout">
			<div class="contact-main">
				{formStatus === "success" ? (
					<div class="contact-success">
						<p>{formMessage}</p>
						<a href="/contact" class="btn">Send another</a>
					</div>
				) : (
					<form method="POST" novalidate class="contact-form">
						{formStatus === "error" && (
							<div role="alert" class="form-error">
								{formMessage}
							</div>
						)}

						<div class="form-field">
							<label for="name">Name</label>
							<input type="text" id="name" name="name" required aria-required="true" autocomplete="name" value={name} />
						</div>

						<div class="form-field">
							<label for="email">Email</label>
							<input type="email" id="email" name="email" required aria-required="true" autocomplete="email" value={email} />
						</div>

						<div class="form-field form-field-wide">
							<label for="message">Message</label>
							<textarea id="message" name="message" required aria-required="true" rows="8">{message}</textarea>
						</div>

						<div class="turnstile-row">
							<div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light" data-appearance="interaction-only"></div>
							<button type="submit" class="btn">Send</button>
						</div>
					</form>
				)}
			</div>

			<aside class="contact-aside">
				<div class="aside-section">
					<label class="aside-label">Direct</label>
					<a href="mailto:contact@adpena.com" class="aside-link">contact@adpena.com</a>
				</div>
				<div class="aside-section">
					<label class="aside-label">Elsewhere</label>
					<a href="https://github.com/adpena" class="aside-link" target="_blank" rel="noopener noreferrer">GitHub</a>
					<a href="https://x.com/adpenatx" class="aside-link" target="_blank" rel="noopener noreferrer">X</a>
					<a href="https://linkedin.com/in/adpena" class="aside-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
				</div>
			</aside>
		</div>
	</main>

	<script>
		// Lazy-load Turnstile only when the form receives focus,
		// so the script doesn't block View Transitions on navigation.
		const form = document.querySelector('.contact-form');
		if (form) {
			let loaded = false;
			form.addEventListener('focusin', () => {
				if (loaded) return;
				loaded = true;
				const s = document.createElement('script');
				s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
				s.async = true;
				document.head.appendChild(s);
			}, { once: true });
		}
	</script>
</Base>
