---
// Molt Mandelbrot demo — Python compiled to Wasm, rendered on canvas
// TODO(molt-compile): Wire "Compile & Run" button to Molt compilation endpoint.
//   When the Molt Rust build is fixed:
//   1. Compile Molt itself to Wasm and deploy as a Cloudflare Worker
//   2. Button POSTs Python source to the compile Worker
//   3. Worker returns compiled .wasm binary
//   4. Browser loads the binary via loadMoltWasm() from browser_host.js
//   5. Replace the JS Mandelbrot preview with actual compiled Wasm output
//   6. Status bar shows "Wasm" instead of "JS preview"
//
// TODO(monty-interpreter): As an intermediate step before Molt compiles,
//   load Monty (Pydantic's Python sandbox) as a Wasm module in the browser.
//   Monty can interpret arbitrary Python live. This enables the MCP agent
//   workflow (write Python → interpret → see result) without needing Molt.
//   Monty's Wasm bundle: check pydantic/monty releases for monty-wasm.
//
// TODO(molt-mcp-compile): Add a compile_and_run MCP tool that:
//   1. Accepts arbitrary Python source
//   2. Sends to the Molt compile Worker (or interprets via Monty)
//   3. Runs the result
//   4. Returns stdout + canvas snapshot
//   This enables fully autonomous AI visual art creation loops.

import MoltDemo from "../../components/MoltDemo.tsx";

const embedParam = Astro.url.searchParams.get("embed");
const embedMode = embedParam === "1" ? "embed"
	: embedParam === "stacked" ? "stacked"
	: "standalone" as const;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Molt — Mandelbrot Demo</title>
  <!-- Self-contained styles: demo page renders outside the main site layout
       as a standalone app and embeddable widget. Hex values intentionally
       duplicate the design tokens for zero-dependency embedding. -->
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f5f0;
      --text: #1a1a1a;
      --secondary: #707070;
      --border: #d4d4cc;
      --mono: "Courier New", ui-monospace, monospace;
      --serif: Georgia, serif;
    }

    body {
      font-family: var(--serif);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    /* Astro island and React root must fill the flex layout */
    astro-island,
    .molt-island {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    header {
      padding: 0.75rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .title {
      font-size: 0.8rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .title a { color: var(--text); text-decoration: none; }

    .note {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--secondary);
    }

    .demo-layout {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: 1fr 1fr;
      min-height: 0;
    }

    .pane {
      display: flex;
      flex-direction: column;
      min-height: 0;
      overflow: hidden;
    }

    .pane-header {
      font-family: var(--mono);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--secondary);
      padding: 0.4rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .pane-left { border-bottom: 1px solid var(--border); }

    .code-wrap {
      flex: 1;
      display: grid;
      grid-template-columns: auto 1fr;
      overflow: auto;
    }

    .line-numbers {
      padding: 1rem 0.5rem 1rem 1rem;
      font-family: var(--mono);
      font-size: 0.75rem;
      line-height: 1.7;
      color: var(--border);
      text-align: right;
      user-select: none;
      white-space: pre;
      border-right: 1px solid var(--border);
    }

    textarea {
      flex: 1;
      padding: 1rem 1rem 1rem 0.75rem;
      font-family: var(--mono);
      font-size: 0.75rem;
      line-height: 1.7;
      color: var(--text);
      background: var(--bg);
      border: none;
      resize: none;
      outline: none;
      tab-size: 4;
      white-space: pre;
      overflow-wrap: normal;
    }

    .canvas-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--text);
      padding: 1rem;
    }

    canvas {
      width: 100%;
      height: 100%;
      object-fit: contain;
      cursor: pointer;
    }

    .btn {
      padding: 0.2rem 0.6rem;
      font-family: var(--mono);
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text);
      background: transparent;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: background 150ms, color 150ms;
    }

    .btn:hover { background: var(--text); color: var(--bg); }
    .btn:disabled { opacity: 0.3; cursor: default; }
    .btn.primary { background: var(--text); color: var(--bg); }
    .btn.primary:hover { opacity: 0.85; }

    .status {
      font-family: var(--mono);
      font-size: 0.6rem;
      color: var(--secondary);
      padding: 0.35rem 1rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
    }

    @media (max-width: 768px) {
      header { flex-wrap: wrap; gap: 0.25rem; padding: 0.5rem 1rem; }
      textarea { white-space: pre-wrap; word-break: break-word; font-size: 1rem; }
      .line-numbers { padding: 0.5rem 0.25rem 0.5rem 0.5rem; font-size: 0.65rem; }
      .code-wrap { grid-template-columns: 2rem 1fr; }
    }

    @media (max-width: 480px) {
      .status { flex-wrap: wrap; gap: 0.25rem; font-size: 0.55rem; }
    }
  </style>
</head>
<body class={embedMode === "embed" ? "embed" : embedMode === "stacked" ? "embed-stacked" : ""}>
  <MoltDemo embedMode={embedMode} client:load />
</body>
</html>
