---
// Molt Mandelbrot demo — Python compiled to Wasm, rendered on canvas
// TODO: Wire to live Molt compilation endpoint once build is fixed
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Molt — Mandelbrot Demo</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f5f0;
      --text: #1a1a1a;
      --secondary: #707070;
      --border: #d4d4cc;
      --mono: "Courier New", ui-monospace, monospace;
      --serif: Georgia, serif;
    }

    body {
      font-family: var(--serif);
      background: var(--bg);
      color: var(--text);
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    header {
      padding: 0.75rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .title {
      font-size: 0.8rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .title a { color: var(--text); text-decoration: none; }

    .note {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--secondary);
    }

    .demo-layout {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: 1fr 1fr;
      min-height: 0;
    }

    .pane {
      display: flex;
      flex-direction: column;
      min-height: 0;
      overflow: hidden;
    }

    .pane-header {
      font-family: var(--mono);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--secondary);
      padding: 0.4rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .pane-left { border-bottom: 1px solid var(--border); }

    .code-wrap {
      flex: 1;
      display: grid;
      grid-template-columns: auto 1fr;
      overflow: auto;
    }

    .line-numbers {
      padding: 1rem 0.5rem 1rem 1rem;
      font-family: var(--mono);
      font-size: 0.75rem;
      line-height: 1.7;
      color: var(--border);
      text-align: right;
      user-select: none;
      white-space: pre;
      border-right: 1px solid var(--border);
    }

    textarea {
      flex: 1;
      padding: 1rem 1rem 1rem 0.75rem;
      font-family: var(--mono);
      font-size: 0.75rem;
      line-height: 1.7;
      color: var(--text);
      background: var(--bg);
      border: none;
      resize: none;
      outline: none;
      tab-size: 4;
      white-space: pre;
      overflow-wrap: normal;
    }

    .canvas-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--text);
      padding: 1rem;
    }

    canvas {
      width: 100%;
      height: 100%;
      object-fit: cover;
      cursor: pointer;
      image-rendering: auto;
    }

    .btn {
      padding: 0.2rem 0.6rem;
      font-family: var(--mono);
      font-size: 0.6rem;
      color: var(--text);
      background: transparent;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: background 150ms, color 150ms;
    }

    .btn:hover { background: var(--text); color: var(--bg); }
    .btn:disabled { opacity: 0.3; cursor: default; }
    .btn.primary { background: var(--text); color: var(--bg); }
    .btn.primary:hover { opacity: 0.85; }

    .status {
      font-family: var(--mono);
      font-size: 0.6rem;
      color: var(--secondary);
      padding: 0.35rem 1rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
    }

    .placeholder-msg {
      color: var(--secondary);
      font-family: var(--mono);
      font-size: 0.7rem;
      text-align: center;
      max-width: 20rem;
      line-height: 1.6;
    }

    /* Embed mode: canvas only, fills the entire iframe */
    .embed header,
    .embed .status,
    .embed .pane-left {
      display: none !important;
    }

    .embed .demo-layout {
      grid-template-columns: 1fr !important;
    }

    .embed .canvas-wrap {
      padding: 0;
    }

    .embed canvas {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .embed body {
      overflow: hidden;
    }

    @media (max-width: 768px) {
      :not(.embed) .demo-layout {
        grid-template-columns: 1fr;
        grid-template-rows: 1fr 1fr;
      }
      :not(.embed) .pane-left {
        border-right: none;
        border-bottom: 1px solid var(--border);
      }
    }
  </style>
</head>
<body>
  <header>
    <span class="title"><a href="/">Molt</a> — Mandelbrot</span>
    <span class="note">Python → Wasm → Canvas</span>
  </header>

  <div class="demo-layout">
    <div class="pane">
      <div class="canvas-wrap" id="canvas-wrap">
        <canvas id="canvas"></canvas>
      </div>
    </div>

    <div class="pane pane-left">
      <div class="pane-header">
        <span>mandelbrot.py</span>
        <div style="display:flex;gap:0.3rem">
          <button class="btn primary" id="compile-btn" disabled>Compile & Run</button>
        </div>
      </div>
      <div class="code-wrap">
        <div class="line-numbers" id="line-numbers"></div>
        <textarea id="code" spellcheck="false"></textarea>
      </div>
    </div>
  </div>

  <div class="status">
    <span id="status-text">Loading source...</span>
    <span id="status-meta"></span>
  </div>

  <script>
    // When embedded in iframe, strip chrome and force side-by-side
    const isEmbed = new URLSearchParams(window.location.search).has('embed') || window.self !== window.top;
    if (isEmbed) {
      document.documentElement.classList.add('embed');
    }

    const codeEl = document.getElementById('code');
    const lineNumEl = document.getElementById('line-numbers');

    function updateLineNumbers() {
      const lines = (codeEl.value || '').split('\n').length;
      lineNumEl.textContent = Array.from({ length: lines }, (_, i) => i + 1).join('\n');
    }

    // Sync scroll between textarea and line numbers
    codeEl.addEventListener('scroll', () => {
      lineNumEl.style.transform = `translateY(-${codeEl.scrollTop}px)`;
    });

    codeEl.addEventListener('input', updateLineNumbers);
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    const compileBtn = document.getElementById('compile-btn');
    const statusText = document.getElementById('status-text');
    const statusMeta = document.getElementById('status-meta');

    // Load the Mandelbrot source, init line numbers, start animation
    fetch('/molt-demo/mandelbrot.py')
      .then(r => r.text())
      .then(src => {
        codeEl.value = src;
        updateLineNumbers();
        if (statusText) statusText.textContent = 'Animating — click canvas to pause';
      });

    // Size canvas to match its actual display size — no scaling artifacts
    const container = document.getElementById('canvas-wrap');
    const rect = container.getBoundingClientRect();
    const W = Math.round(rect.width) || 640;
    const H = Math.round(rect.height) || 400;
    canvas.width = W;
    canvas.height = H;

    const TARGET_X = -0.7453;
    const TARGET_Y = 0.1127;
    let zoom = 1.0;
    let frame = 0;
    let animating = true;
    let rendering = false;

    // Off-thread rendering via Web Worker
    const worker = new Worker('/molt-demo/mandelbrot-worker.js');

    worker.onmessage = (e) => {
      const { buf, W: w, H: h } = e.data;
      const img = new ImageData(new Uint8ClampedArray(buf), w, h);
      ctx.putImageData(img, 0, 0);
      rendering = false;
    };

    function parseParams() {
      const src = codeEl.value;
      const p = (name, fb) => {
        const m = src.match(new RegExp(name + '\\s*[:=]\\s*([\\-0-9.]+)'));
        return m ? parseFloat(m[1]) : fb;
      };
      return {
        maxIter: p('MAX_ITER', 100),
        cx: p('CENTER_X', TARGET_X),
        cy: p('CENTER_Y', TARGET_Y),
      };
    }

    function requestRender() {
      if (rendering) return;
      rendering = true;
      const { maxIter, cx, cy } = parseParams();
      const dynamicIter = Math.min(800, Math.max(maxIter, 50 + Math.floor(Math.log(zoom + 1) * 40)));
      worker.postMessage({ W, H, cx, cy, zoom, maxIter: dynamicIter, colorShift: frame * 0.08 });
    }

    function animate() {
      if (!animating) return;
      zoom *= 1.0015;
      if (zoom > 1e12) zoom = 1.0;
      frame++;

      requestRender();

      if (statusMeta) {
        const dynIter = Math.min(800, 50 + Math.floor(Math.log(zoom + 1) * 40));
        statusMeta.textContent = `${W}×${H} · zoom: ${zoom.toFixed(1)}x · iter: ${dynIter} · frame ${frame}`;
      }
      requestAnimationFrame(animate);
    }

    // Start immediately
    requestRender();
    requestAnimationFrame(animate);

    canvas.addEventListener('click', () => {
      animating = !animating;
      if (animating) requestAnimationFrame(animate);
      if (statusText) statusText.textContent = animating ? 'Animating' : 'Paused — click to resume';
    });

    codeEl.addEventListener('input', () => {
      animating = false;
      if (statusText) statusText.textContent = 'Paused — editing';
      updateLineNumbers();
      requestRender();
    });
  </script>
</body>
</html>
