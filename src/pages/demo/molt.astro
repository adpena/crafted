---
// Molt live demo — Python compiled to Wasm, running in the browser
// No interpreter. No Pyodide. No cold start.
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Molt — Live Demo</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f5f0;
      --text: #1a1a1a;
      --secondary: #707070;
      --border: #d4d4cc;
      --surface: #eeeee8;
      --mono: "Courier New", ui-monospace, monospace;
      --serif: Georgia, serif;
    }

    body {
      font-family: var(--serif);
      background: var(--bg);
      color: var(--text);
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    header {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .title {
      font-size: 0.875rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .title a {
      color: var(--text);
      text-decoration: none;
    }

    .subtitle {
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--secondary);
    }

    .demo-layout {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 0;
    }

    .pane {
      display: flex;
      flex-direction: column;
      min-height: 0;
      overflow: hidden;
    }

    .pane-header {
      font-family: var(--mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--secondary);
      padding: 0.5rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .pane-left {
      border-right: 1px solid var(--border);
    }

    textarea {
      flex: 1;
      padding: 1rem;
      font-family: var(--mono);
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--text);
      background: var(--bg);
      border: none;
      resize: none;
      outline: none;
      tab-size: 4;
    }

    .output {
      flex: 1;
      padding: 1rem;
      font-family: var(--mono);
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--secondary);
      background: var(--text);
      overflow: auto;
      white-space: pre-wrap;
    }

    .output.running {
      color: #a0a0a0;
    }

    .btn {
      padding: 0.25rem 0.75rem;
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--text);
      background: transparent;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: background 150ms, color 150ms;
    }

    .btn:hover {
      background: var(--text);
      color: var(--bg);
    }

    .btn:disabled {
      opacity: 0.4;
      cursor: default;
    }

    .status {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--secondary);
      padding: 0.4rem 1rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
    }

    @media (max-width: 768px) {
      .demo-layout {
        grid-template-columns: 1fr;
        grid-template-rows: 1fr 1fr;
      }

      .pane-left {
        border-right: none;
        border-bottom: 1px solid var(--border);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      * { transition-duration: 0ms !important; }
    }
  </style>
</head>
<body>
  <header>
    <span class="title"><a href="/">Molt</a></span>
    <span class="subtitle">Python compiled to WebAssembly — no interpreter</span>
  </header>

  <div class="demo-layout">
    <div class="pane pane-left">
      <div class="pane-header">
        <span>app.py</span>
        <button class="btn" id="run-btn">Run</button>
      </div>
      <textarea id="code" spellcheck="false" readonly></textarea>
    </div>

    <div class="pane">
      <div class="pane-header">
        <span>Output</span>
        <button class="btn" id="clear-btn">Clear</button>
      </div>
      <div class="output" id="output"></div>
    </div>
  </div>

  <div class="status">
    <span id="status-text">Ready</span>
    <span id="status-meta"></span>
  </div>

  <script type="module">
    const codeEl = document.getElementById('code');
    const outputEl = document.getElementById('output');
    const runBtn = document.getElementById('run-btn');
    const clearBtn = document.getElementById('clear-btn');
    const statusText = document.getElementById('status-text');
    const statusMeta = document.getElementById('status-meta');

    // Load the source code
    fetch('/molt-demo/app.py')
      .then(r => r.text())
      .then(src => {
        // Show just the interesting parts (skip the huge GPT weights)
        const lines = src.split('\n');
        const weightStart = lines.findIndex(l => l.includes('_GPT_W'));
        const weightEnd = lines.findIndex((l, i) => i > weightStart && l.startsWith(')'));

        if (weightStart > 0 && weightEnd > 0) {
          const before = lines.slice(0, weightStart).join('\n');
          const after = lines.slice(weightEnd + 1).join('\n');
          codeEl.value = before + '\n# [4,192 GPT parameters — weights omitted for display]\n_GPT_W = "..."\n' + after;
        } else {
          codeEl.value = src;
        }
      });

    function log(msg) {
      outputEl.textContent += msg + '\n';
      outputEl.scrollTop = outputEl.scrollHeight;
    }

    clearBtn.addEventListener('click', () => {
      outputEl.textContent = '';
    });

    runBtn.addEventListener('click', async () => {
      runBtn.disabled = true;
      outputEl.classList.add('running');
      outputEl.textContent = '';
      statusText.textContent = 'Loading WASM...';

      const t0 = performance.now();

      try {
        const { loadMoltWasm } = await import('/molt-demo/browser_host.js');

        statusText.textContent = 'Instantiating...';
        const host = await loadMoltWasm({
          linkedUrl: '/molt-demo/output_linked.wasm',
          log: (level, msg) => {
            if (level === 'stdout') {
              log(msg);
            } else if (level !== 'trace') {
              log(`[${level}] ${msg}`);
            }
          },
        });

        const t1 = performance.now();
        statusText.textContent = 'Running...';

        host.run();

        const t2 = performance.now();
        const loadMs = Math.round(t1 - t0);
        const execMs = Math.round(t2 - t1);

        statusText.textContent = 'Done';
        statusMeta.textContent = `Load: ${loadMs}ms · Execute: ${execMs}ms · Binary: 5.2MB`;
        outputEl.classList.remove('running');
      } catch (err) {
        log(`Error: ${err.message}`);
        statusText.textContent = 'Error';
        console.error(err);
      }

      runBtn.disabled = false;
    });
  </script>
</body>
</html>
