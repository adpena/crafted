---
interface Props {
	currentPath?: string;
	siteTitle?: string;
	tagline?: string;
}

const { currentPath = "", siteTitle = "Studio", tagline = "Design & Development" } = Astro.props;

const navLinks = [
	{ label: "Work", href: "/work" },
	{ label: "About", href: "/about" },
	{ label: "Contact", href: "/contact" },
];

function isActive(href: string): boolean {
	if (href === "/") return currentPath === "/";
	return currentPath.startsWith(href);
}
---

<header role="banner" class="masthead">
	<div class="masthead-inner">
		<a href="/" class="masthead-title">{siteTitle}</a>
		<p class="masthead-tagline">{tagline}</p>
		<nav aria-label="Main navigation" class="masthead-nav">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class:list={["masthead-nav-link", { active: isActive(link.href) }]}
					aria-current={isActive(link.href) ? "page" : undefined}
				>{link.label}</a>
			))}
		</nav>
	</div>
</header>

<style>
	.masthead {
		border-bottom: 2px solid var(--color-text);
		padding: var(--spacing-xl) 0 var(--spacing-lg);
	}

	.masthead-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--content-padding);
		text-align: center;
	}

	.masthead-title {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		text-decoration: none;
		color: var(--color-text);
		line-height: 1.1;
		transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.masthead-title:hover {
		color: var(--color-secondary);
	}

	.masthead-tagline {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-top: var(--spacing-xs);
		letter-spacing: 0.04em;
	}

	.masthead-nav {
		display: flex;
		justify-content: center;
		gap: var(--spacing-xl);
		margin-top: var(--spacing-md);
		padding-top: var(--spacing-md);
		border-top: 1px solid var(--color-border);
	}

	.masthead-nav-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		text-decoration: none;
		color: var(--color-secondary);
		text-decoration-line: underline;
		text-decoration-color: transparent;
		text-decoration-thickness: 2px;
		text-underline-offset: 4px;
		transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1), text-decoration-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.masthead-nav-link:hover {
		color: var(--color-text);
		text-decoration-color: var(--color-border);
	}

	.masthead-nav-link.active {
		color: var(--color-text);
		text-decoration-color: var(--color-text);
	}

	@media (max-width: 768px) {
		.masthead-nav-link {
			min-height: 44px;
			display: inline-flex;
			align-items: center;
		}
	}

	@media (max-width: 640px) {
		.masthead-title {
			font-size: var(--font-size-2xl);
			letter-spacing: 0.12em;
		}

		.masthead-nav {
			flex-wrap: wrap;
			gap: var(--spacing-md);
		}
	}

	@media (max-width: 375px) {
		.masthead-title {
			font-size: 1.375rem;
			letter-spacing: 0.08em;
		}

		.masthead-nav {
			gap: var(--spacing-sm);
		}
	}
</style>
