---
import { getSiteSettings } from "emdash";

interface Props {
	currentPath?: string;
}

const { currentPath = "" } = Astro.props;
const settings = await getSiteSettings();
const siteTitle = settings?.title || "Studio";
const tagline = settings?.tagline || "Design & Development";

const navLinks = [
	{ label: "Work", href: "/work" },
	{ label: "About", href: "/about" },
	{ label: "Contact", href: "/contact" },
];

function isActive(href: string): boolean {
	if (href === "/") return currentPath === "/";
	return currentPath.startsWith(href);
}
---

<header role="banner" class="masthead">
	<div class="masthead-inner">
		<a href="/" class="masthead-title">{siteTitle}</a>
		<p class="masthead-tagline">{tagline}</p>
		<nav aria-label="Main navigation" class="masthead-nav">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class:list={["masthead-nav-link", { active: isActive(link.href) }]}
					aria-current={isActive(link.href) ? "page" : undefined}
				>{link.label}</a>
			))}
		</nav>
	</div>
</header>

<style>
	.masthead {
		border-bottom: 2px solid var(--color-text);
		padding: var(--spacing-xl) 0 var(--spacing-lg);
	}

	.masthead-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--content-padding);
		text-align: center;
	}

	.masthead-title {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 700;
		font-variant: small-caps;
		letter-spacing: 0.1em;
		text-decoration: none;
		color: var(--color-text);
		line-height: 1.1;
	}

	.masthead-tagline {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-top: var(--spacing-xs);
		letter-spacing: 0.04em;
	}

	.masthead-nav {
		display: flex;
		justify-content: center;
		gap: var(--spacing-xl);
		margin-top: var(--spacing-md);
		padding-top: var(--spacing-md);
		border-top: 1px solid var(--color-border);
	}

	.masthead-nav-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		text-decoration: none;
		color: var(--color-secondary);
		transition: color 150ms ease;
	}

	.masthead-nav-link:hover,
	.masthead-nav-link.active {
		color: var(--color-text);
	}

	.masthead-nav-link.active {
		border-bottom: 1px solid var(--color-text);
		padding-bottom: 2px;
	}

	@media (max-width: 640px) {
		.masthead-title {
			font-size: var(--font-size-2xl);
		}

		.masthead-nav {
			flex-wrap: wrap;
			gap: var(--spacing-md);
		}
	}
</style>
