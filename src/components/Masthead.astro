---
interface Props {
	currentPath?: string;
	siteTitle?: string;
	tagline?: string;
}

const { currentPath = "", siteTitle = "Studio", tagline = "Design & Development" } = Astro.props;

const navLinks = [
	{ label: "Work", href: "/" },
	{ label: "About", href: "/about" },
	{ label: "Contact", href: "/contact" },
];

function isActive(href: string): boolean {
	if (href === "/") return currentPath === "/";
	return currentPath.startsWith(href);
}
---

<header role="banner" class="masthead">
	<div class="masthead-inner">
		<a href="/" class="masthead-title">{siteTitle}</a>
		<p class="masthead-tagline">{tagline}</p>
		<nav aria-label="Main navigation" class="masthead-nav">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class:list={["masthead-nav-link", { active: isActive(link.href) }]}
					aria-current={isActive(link.href) ? "page" : undefined}
				>{link.label}</a>
			))}
			<button
				class="theme-toggle"
				id="theme-toggle"
				aria-label="Toggle dark mode"
				type="button"
			>
				<span class="theme-toggle-icon" aria-hidden="true"></span>
			</button>
		</nav>
	</div>
</header>

<style>
	.masthead {
		border-bottom: 2px solid var(--color-text);
		padding: var(--spacing-xl) 0 0;
	}

	.masthead-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--content-padding);
		text-align: center;
	}

	.masthead-title {
		display: block;
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		text-decoration: none;
		color: var(--color-text);
		line-height: 1.1;
		transition: color 200ms var(--ease);
	}

	.masthead-title:hover {
		color: var(--color-secondary);
	}

	.masthead-title:visited,
	.masthead-title:active {
		color: var(--color-text);
	}

	.masthead-tagline {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-top: var(--spacing-xs);
		letter-spacing: 0.04em;
	}

	.masthead-nav {
		display: flex;
		justify-content: center;
		gap: var(--spacing-xl);
		margin-top: var(--spacing-md);
		padding: var(--spacing-sm) 0;
		border-top: 1px solid var(--color-border);
	}

	.masthead-nav-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		text-decoration: none;
		color: var(--color-secondary);
		text-decoration-line: underline;
		text-decoration-color: transparent;
		text-decoration-thickness: 2px;
		text-underline-offset: 4px;
		transition: color 200ms var(--ease), text-decoration-color 200ms var(--ease);
	}

	.masthead-nav-link:visited {
		color: var(--color-secondary);
	}

	.masthead-nav-link:active {
		color: var(--color-secondary);
	}

	.masthead-nav-link:hover {
		color: var(--color-text);
		text-decoration-color: var(--color-border);
	}

	.masthead-nav-link.active,
	.masthead-nav-link.active:visited {
		color: var(--color-text);
		text-decoration-color: var(--color-text);
	}

	@media (max-width: 768px) {
		.masthead {
			padding: var(--spacing-md) 0 0;
		}

		.masthead-title {
			letter-spacing: 0.15em;
			min-height: 44px;
			display: inline-flex;
			align-items: center;
		}

		.masthead-nav-link {
			min-height: 44px;
			display: inline-flex;
			align-items: center;
		}
	}

	@media (max-width: 640px) {
		.masthead-title {
			font-size: var(--font-size-2xl);
			letter-spacing: 0.12em;
		}

		.masthead-nav {
			flex-wrap: wrap;
			gap: var(--spacing-md);
		}
	}

	@media (max-width: 375px) {
		.masthead-title {
			font-size: 1.375rem;
			letter-spacing: 0.08em;
		}

		.masthead-nav {
			gap: var(--spacing-sm);
		}
	}

	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.25rem;
		margin-left: var(--spacing-sm);
		color: var(--color-secondary);
		transition: color 200ms var(--ease);
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		min-width: 44px;
		justify-content: center;
	}

	.theme-toggle:hover {
		color: var(--color-text);
	}

	/* Sun icon (light mode) */
	.theme-toggle-icon::before {
		content: "☀";
		font-size: 1rem;
	}

	/* Moon icon (dark mode) */
	:global(:root[data-theme="dark"]) .theme-toggle-icon::before,
	:global(:root:not([data-theme="light"])) .theme-toggle-icon::before {
		content: "☀";
	}

	@media (prefers-color-scheme: dark) {
		:global(:root:not([data-theme="light"])) .theme-toggle-icon::before {
			content: "☾";
		}
	}

	:global(:root[data-theme="dark"]) .theme-toggle-icon::before {
		content: "☾";
	}
</style>

<script>
	const toggle = document.getElementById('theme-toggle');
	if (toggle) {
		// Read saved preference
		const saved = localStorage.getItem('theme');
		if (saved) document.documentElement.setAttribute('data-theme', saved);

		toggle.addEventListener('click', () => {
			const current = document.documentElement.getAttribute('data-theme');
			const isDark = current === 'dark' ||
				(!current && window.matchMedia('(prefers-color-scheme: dark)').matches);
			const next = isDark ? 'light' : 'dark';
			document.documentElement.setAttribute('data-theme', next);
			localStorage.setItem('theme', next);
		});
	}
</script>
