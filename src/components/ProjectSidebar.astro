---
interface Props {
	stack?: string[];
	url?: string;
	year?: string;
	status?: string;
}

const { stack = [], url, year, status } = Astro.props;
const isActive = status === "Active" || status === "active";
---

<aside class="project-sidebar" aria-label="Project details">
	{stack.length > 0 && (
		<div class="sidebar-section">
			<h3 class="sidebar-label">Stack</h3>
			<ul class="sidebar-tags">
				{stack.map((tag) => (
					<li>{tag}</li>
				))}
			</ul>
		</div>
	)}

	{url && (
		<div class="sidebar-section">
			<h3 class="sidebar-label">Links</h3>
			<a href={url} target="_blank" rel="noopener noreferrer" class="sidebar-link">
				Visit site &rarr;
			</a>
		</div>
	)}

	{year && (
		<div class="sidebar-section">
			<h3 class="sidebar-label">Year</h3>
			<span class="sidebar-value">{year}</span>
		</div>
	)}

	{status && (
		<div class="sidebar-section">
			<h3 class="sidebar-label">Status</h3>
			<span class="sidebar-status">
				{isActive && <span class="status-dot" aria-hidden="true" />}
				{status}
			</span>
		</div>
	)}
</aside>

<style>
	.project-sidebar {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
	}

	.sidebar-section {
		margin-bottom: var(--spacing-xl);
	}

	.sidebar-label {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-secondary);
		margin-bottom: var(--spacing-sm);
	}

	.sidebar-tags {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xs);
		color: var(--color-text);
	}

	.sidebar-link {
		color: var(--color-text);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.sidebar-link:hover {
		color: var(--color-secondary);
	}

	.sidebar-value {
		color: var(--color-text);
	}

	.sidebar-status {
		display: inline-flex;
		align-items: center;
		color: var(--color-text);
	}

	.status-dot {
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-accent);
		margin-right: var(--spacing-xs);
	}
</style>
