---
const socialLinks = [
	{ label: "GitHub", url: "https://github.com/adpena" },
	{ label: "Twitter", url: "https://twitter.com/adpenatx" },
	{ label: "LinkedIn", url: "https://linkedin.com/in/adpena" },
].filter((link) => link.url);
---

<footer class="site-footer" role="contentinfo">
	<p class="colophon">built with emdash (WordPress at the edge) + astro + cloudflare</p>
	{socialLinks.length > 0 && (
		<nav aria-label="Social links" class="social-nav">
			{socialLinks.map((link, i) => (
				<Fragment>
					{i > 0 && <span class="sep" aria-hidden="true">&middot;</span>}
					<a href={link.url} class="social-link" target="_blank" rel="noopener noreferrer">
						{link.label}
					</a>
				</Fragment>
			))}
		</nav>
	)}
</footer>

<style>
	.site-footer {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-md) var(--content-padding) var(--spacing-lg);
		border-top: 1px solid var(--color-border);
		text-align: center;
	}

	.colophon {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		margin-bottom: var(--spacing-sm);
	}

	.social-nav {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--spacing-md);
	}

	.sep {
		color: var(--color-border);
		font-size: var(--font-size-xs);
	}

	.social-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-secondary);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.social-link:hover {
		color: var(--color-text);
	}
</style>
