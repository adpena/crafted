		"dev_projects": [
			{
				"id": "molt",
				"slug": "molt",
				"status": "published",
				"data": {
					"title": "Molt",
					"year": "2026",
					"summary": "An ahead-of-time Python-to-WebAssembly compiler with aggressive tree shaking and deforestation.",
					"repo_url": "https://github.com/adpena/molt",
					"stack": "Rust, Python, Wasm",
					"language": "Rust",
					"project_status": "Active",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [{ "_type": "span", "text": "Molt is an ahead-of-time compiler that takes Python source and emits WebAssembly. The goal is not to run arbitrary Python in the browser -- Molt targets a narrower problem: take the Python you actually wrote, strip everything you did not use, and produce a small, fast Wasm module that can run on Cloudflare Workers or any other edge runtime." }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [{ "_type": "span", "text": "The compiler parses Python into an AST, runs type inference, then applies aggressive tree shaking and deforestation to eliminate dead code and intermediate data structures. The output is Wasm bytecode linked against libmolt, a small C ABI runtime. The result is a binary measured in kilobytes, not megabytes." }]
						}
					]
				}
			},
			{
				"id": "crafted-action-pages",
				"slug": "crafted-action-pages",
				"status": "published",
				"data": {
					"title": "Crafted Action Pages",
					"year": "2026",
					"summary": "Campaign action page engine with FEC/state disclaimer compliance, geo-personalized donation asks, and edge A/B testing.",
					"repo_url": "https://github.com/adpena/crafted",
					"stack": "TypeScript, Astro, Cloudflare Workers, D1",
					"language": "TypeScript",
					"project_status": "Active",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [{ "_type": "span", "text": "Progressive campaigns need action pages -- donation forms, petition signatures, volunteer sign-ups -- and they need them fast. Crafted Action Pages is an emdash plugin that renders action pages at the edge on Cloudflare with the correct FEC and state-level disclaimer for the visitor's jurisdiction." }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [{ "_type": "span", "text": "The plugin ships with an open-source compliance dataset covering federal rules and 10 state-specific disclaimer requirements. Donation asks are geo-personalized, pages support edge A/B testing, spam protection uses Cloudflare Turnstile, and donation flows deep-link into ActBlue." }]
						}
					]
				}
			}
		]
