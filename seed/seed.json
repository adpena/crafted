					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Systems engineer and compiler author. I build infrastructure that makes other things work better. Currently focused on Python-to-Wasm compilation and campaign technology for progressive causes. Previously: Django, WordPress, frontend web development."
								}
							]
						}
					]
